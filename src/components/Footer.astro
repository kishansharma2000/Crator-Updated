<footer class="footer">
  <div class="footer-inner">
    <a href="/" class="footer-logo">
      <img src="https://www.cratorlabs.ai/_next/image?url=%2Ffull-logo.png&w=256&q=75" alt="Crator" height="22" />
    </a>
    <div class="footer-policies">
      <a href="/privacy">Privacy</a>
      <span class="footer-sep">·</span>
      <a href="/terms-of-service">Terms</a>
      <span class="footer-sep">·</span>
      <a href="https://trust.cratorlabs.ai" target="_blank" rel="noopener">Security</a>
    </div>
    <p class="footer-copy">&copy; 2026 Crator Labs. Applied AI Company, Singapore.</p>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--border);
    padding: 2rem 2rem;
  }
  .footer-inner {
    max-width: var(--max-w);
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1.5rem;
  }
  .footer-logo {
    display: flex;
    align-items: center;
  }
  .footer-logo img {
    height: 22px;
    width: auto;
  }
  .footer-policies {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .footer-policies a {
    font-size: 0.8125rem;
    color: var(--text-2);
    text-decoration: none;
    transition: color 0.15s;
  }
  .footer-policies a:hover {
    color: var(--text-1);
  }
  .footer-sep {
    color: var(--text-3);
    font-size: 0.75rem;
  }
  .footer-copy {
    font-size: 0.75rem;
    color: var(--text-3);
  }

  @media (max-width: 600px) {
    .footer-inner {
      flex-direction: column;
      align-items: flex-start;
      gap: 1rem;
    }
    .footer-copy {
      margin-left: 0;
    }
  }
</style>