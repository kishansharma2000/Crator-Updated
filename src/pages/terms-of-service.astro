<style>
	:root {
		--bg: #fff;
		--surface: #f7f7f7;
		--border: rgba(0,0,0,0.08);
		--border-mid: rgba(0,0,0,0.14);
		--text-1: #000;
		--text-2: rgba(0,0,0,0.5);
		--text-3: rgba(0,0,0,0.3);
		--accent: #4A93D6;
		--max-w: 720px;
	}

	.page-rails {
		position: fixed;
		top: 0; bottom: 0;
		left: 50%; transform: translateX(-50%);
		width: min(var(--max-w), 100vw);
		pointer-events: none;
		z-index: 40;
		border-left: 1px solid var(--border);
		border-right: 1px solid var(--border);
	}

	.policy-main {
		max-width: var(--max-w);
		margin: 0 auto;
		padding: 8rem 2rem 6rem;
	}

	.policy-header {
		margin-bottom: 3rem;
		padding-bottom: 2rem;
		border-bottom: 1px solid var(--border);
	}

	.policy-updated {
		font-size: 0.6875rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--text-3);
		margin-bottom: 1rem;
	}

	.policy-header h1 {
		font-size: clamp(2rem, 4vw, 2.75rem);
		font-weight: 300;
		letter-spacing: -0.03em;
		line-height: 1.1;
		color: var(--text-1);
	}

	.policy-content {
		font-size: 0.9375rem;
		color: var(--text-2);
		line-height: 1.8;
	}

	.policy-intro {
		margin-bottom: 2rem;
	}

	.policy-content h2 {
		font-family: 'IBM Plex Sans', sans-serif;
		font-size: 1.25rem;
		font-weight: 500;
		color: var(--text-1);
		letter-spacing: -0.02em;
		margin-top: 2.5rem;
		margin-bottom: 1rem;
	}

	.policy-content p {
		margin-bottom: 1rem;
	}

	.policy-content ul {
		margin: 1rem 0 1rem 1.5rem;
		list-style: disc;
	}

	.policy-content li {
		margin-bottom: 0.5rem;
	}

	.policy-content strong {
		color: var(--text-1);
		font-weight: 500;
	}

	.highlight {
		background: #f7f7f7;
		padding: 1rem;
		border-radius: 6px;
		border-left: 3px solid var(--accent);
		font-size: 0.875rem;
	}

	.policy-footer-text {
		margin-top: 3rem;
		padding-top: 2rem;
		border-top: 1px solid var(--border);
		font-style: italic;
	}

	/* Footer */
	.policy-footer {
		border-top: 1px solid var(--border);
		padding: 2rem 0;
	}
	.footer-inner {
		max-width: var(--max-w);
		margin: 0 auto;
		padding: 0 2rem;
		display: flex;
		align-items: center;
		justify-content: space-between;
		flex-wrap: wrap;
		gap: 1.5rem;
	}
	.footer-logo {
		display: flex; align-items: center;
	}
	.footer-logo img { height: 22px; width: auto; }
	.footer-policies { display: flex; align-items: center; gap: 0.5rem; }
	.footer-policies a {
		font-size: 0.8125rem; color: var(--text-2);
		text-decoration: none; transition: color 0.15s;
	}
	.footer-policies a:hover { color: var(--text-1); }
	.footer-sep { color: var(--text-3); font-size: 0.75rem; }
	.footer-copy { font-size: 0.75rem; color: var(--text-3); }

	@media (max-width: 600px) {
		.footer-inner { flex-direction: column; align-items: flex-start; gap: 1rem; }
	}
</style>