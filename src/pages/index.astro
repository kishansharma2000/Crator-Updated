<script>
const titles = { overview: 'Operations Overview', agents: 'AI Agents', analytics: 'Analytics', integrations: 'Integrations' };
document.querySelectorAll('.sidebar-item[data-view]').forEach(btn => {
	btn.addEventListener('click', () => {
		const view = btn.dataset.view;
		document.querySelectorAll('.sidebar-item').forEach(b => b.classList.remove('active'));
		btn.classList.add('active');
		document.querySelectorAll('.app-view').forEach(p => p.classList.add('hidden'));
		document.querySelector(`.app-view[data-panel="${view}"]`).classList.remove('hidden');
		document.getElementById('app-title').textContent = titles[view];
	});
});
</script>

<script>
		const nav = document.querySelector('.nav');
		window.addEventListener('scroll', () => {
			if (window.scrollY > 50) {
				nav.classList.add('scrolled');
			} else {
				nav.classList.remove('scrolled');
			}
		});
		
		// Auto-cycle mockup tabs
		const tabs = ['overview', 'agents', 'analytics', 'integrations'];
		let currentTab = 0;
		const cycleTabs = () => {
			const currentIndex = tabs[currentTab];
			document.querySelectorAll('.app-view').forEach(p => p.classList.add('hidden'));
			document.querySelector(`.app-view[data-panel="${currentIndex}"]`).classList.remove('hidden');
			document.querySelectorAll('.sidebar-item, .work-card-index').forEach((el, i) => {
				el.classList.toggle('active', i === currentTab);
			});
			currentTab = (currentTab + 1) % tabs.length;
		};
		setInterval(cycleTabs, 2000);
	</script>
	
