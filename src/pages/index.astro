		margin: 0 auto;
		padding: 6rem 2rem;
	}
	.section-header {
		margin-bottom: 3.5rem;
	}
	.section-tag {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		font-size: 0.6875rem;
		font-weight: 600;
		color: var(--text-3);
		letter-spacing: 0.08em;
		text-transform: uppercase;
		margin-bottom: 1.5rem;
	}
	.tag-num {
		font-size: 0.625rem;
		font-weight: 700;
		color: var(--text-3);
		border: 1px solid var(--border-mid);
		border-radius: 4px;
		padding: 0.125rem 0.375rem;
		letter-spacing: 0.04em;
	}
	.section-heading {
		font-family: 'IBM Plex Sans', sans-serif;
		font-size: clamp(1.75rem, 4vw, 2.5rem);
		font-weight: 300;
		line-height: 1.1;
		letter-spacing: -0.03em;
		color: var(--text-1);
		margin-bottom: 1.25rem;
	}
	.section-heading--large {
		font-size: clamp(2.5rem, 5.5vw, 4rem);
	}
	.section-sub {
		font-size: 1rem;
		color: var(--text-2);
		line-height: 1.7;
		max-width: 520px;
	}

	/* ─── Phases (Services) ──────────────────────────────────── */
	.phases {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1.25rem;
	}
	.phase-item {
		background: #fff;
		border: 1px solid var(--border);
		border-radius: 8px;
		padding: 2.25rem 2rem;
		display: flex;
		flex-direction: column;
		gap: 1rem;
		transition: transform 0.2s;
	}
	.phase-item:hover {
		transform: translateY(-2px);
	}
	.phase-top {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
	}
	.phase-num {
		display: none;
	}
	.phase-when {
		font-size: 0.5625rem;
		color: var(--text-3);
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		border: 1px solid var(--border);
		padding: 0.125rem 0.375rem;
		border-radius: 20px;
		flex-shrink: 0;
	}
	.phase-item h3 {
		font-size: 1.375rem;
		font-weight: 400;
		color: var(--text-1);
		letter-spacing: -0.02em;
		line-height: 1.2;
	}
	.phase-item p {
		font-size: 0.875rem;
		color: var(--text-2);
		line-height: 1.7;
	}

	/* ─── Work grid ──────────────────────────────────────────── */
	.work-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 1px;
		background: var(--border);
		border: 1px solid var(--border);
		border-radius: 12px;
		overflow: hidden;
	}
	.work-grid--3 { 
		grid-template-columns: repeat(3, 1fr); 
	}
	@media (max-width: 1100px) {
		.work-grid--3 { grid-template-columns: repeat(2, 1fr); }
	}

	/* ─── Custom Software Sticky Layout ───────────────────────── */
	.section-inner--sticky {
		display: grid;
		grid-template-columns: 420px 1fr;
		gap: 4rem;
		align-items: start;
	}
	.section-sticky {
		position: sticky;
		top: 8rem;
		height: fit-content;
	}
	.section-sticky .section-tag,
	.section-sticky .section-heading,
	.section-sticky .section-sub {
		max-width: 380px;
	}
	.work-cards-scroll {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}
	.work-cards-scroll .work-card {
		border: 1px solid var(--border);
		border-radius: 8px;
		opacity: 0;
		transform: translateY(20px);
		transition: opacity 0.6s ease, transform 0.6s ease, background 0.3s, box-shadow 0.3s ease;
	}
	.work-cards-scroll .work-card.in-view {
		opacity: 1;
		transform: translateY(0);
	}
	.work-cards-scroll .work-card:nth-child(1) { transition-delay: 0s; }
	.work-cards-scroll .work-card:nth-child(2) { transition-delay: 0.1s; }
	.work-cards-scroll .work-card:nth-child(3) { transition-delay: 0.2s; }
	.work-cards-scroll .work-card:nth-child(4) { transition-delay: 0.3s; }
	.work-cards-scroll .work-card:nth-child(5) { transition-delay: 0.4s; }

	@media (max-width: 1024px) {
		.section-inner--sticky {
			grid-template-columns: 1fr;
		}
		.section-sticky {
			position: static;
		}
	}
	.work-card {
		background: var(--bg);
		padding: 2rem;
		text-decoration: none;
		color: inherit;
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
		transition: background 0.15s;
		position: relative;
	}
	.work-card:hover { background: #fafafa; }
	.work-card:hover .work-card-arrow { opacity: 1; transform: translateX(0); }
	.work-card--featured { background: #fafafa; }
	.work-card-index {
		/* removed */
	}
	.work-card-client {
		font-size: 0.625rem;
		font-weight: 600;
		color: var(--text-3);
		text-transform: uppercase;
		letter-spacing: 0.06em;
		margin-bottom: 0.375rem;
	}
	.work-card-top { flex: 1; }
	.work-card-top h3 {
		font-size: 1.0625rem;
		font-weight: 400;
		color: var(--text-1);
		margin-bottom: 0.625rem;
		letter-spacing: -0.015em;
		line-height: 1.3;
	}
	.work-card-top p {
		font-size: 0.8125rem;
		color: var(--text-2);
		line-height: 1.65;
	}
	.work-card-footer {
		display: flex;
		align-items: center;
		justify-content: space-between;
	}
	.work-card-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.375rem;
	}
	.work-card-tags span {
		font-size: 0.5625rem;
		font-weight: 600;
		color: var(--text-3);
		background: rgba(0,0,0,0.04);
		border: 1px solid var(--border);
		padding: 0.1875rem 0.5rem;
		border-radius: 3px;
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}
	.work-card-arrow {
		font-size: 1rem;
		color: var(--text-1);
		opacity: 0;
		transform: translateX(-6px);
		transition: opacity 0.2s, transform 0.2s;
		flex-shrink: 0;
	}

	/* ─── Agent Cards ─────────────────────────────────────────── */
	.agent-layout {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 1.5rem;
	}
	.agent-card {
		background: var(--bg);
		border: 1px solid var(--border);
		border-radius: 12px;
		padding: 1.75rem;
		text-decoration: none;
		color: inherit;
		display: flex;
		flex-direction: column;
		gap: 1rem;
		transition: all 0.2s ease;
		position: relative;
		overflow: hidden;
	}
	.agent-card:hover {
		border-color: var(--text-3);
		transform: translateY(-2px);
		box-shadow: 0 8px 30px rgba(0,0,0,0.08);
	}
	.agent-badge {
		display: inline-flex;
		font-size: 0.5625rem;
		font-weight: 700;
		color: #000;
		background: #f5f5f5;
		padding: 0.25rem 0.625rem;
		border-radius: 4px;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		width: fit-content;
	}
	.agent-client {
		position: absolute;
		top: 1rem;
		right: 1rem;
	}
	.agent-client img {
		height: 24px;
		width: auto;
		opacity: 0.5;
	}
	.agent-icon {
		width: 48px;
		height: 48px;
		background: #f5f5f5;
		border-radius: 10px;
		display: flex;
		align-items: center;
		justify-content: center;
	}
	.agent-icon i {
		font-size: 1.5rem;
		color: var(--text-1);
	}
	.agent-content {
		flex: 1;
	}
	.agent-content h3 {
		font-size: 1.125rem;
		font-weight: 500;
		color: var(--text-1);
		letter-spacing: -0.02em;
		margin-bottom: 0.625rem;
	}
	.agent-content p {
		font-size: 0.8125rem;
		color: var(--text-2);
		line-height: 1.65;
	}
	.agent-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.375rem;
	}
	.agent-tags span {
		font-size: 0.5625rem;
		font-weight: 600;
		color: var(--text-3);
		background: rgba(0,0,0,0.04);
		border: 1px solid var(--border);
		padding: 0.1875rem 0.5rem;
		border-radius: 3px;
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}
	@media (max-width: 768px) {
		.agent-layout {
			grid-template-columns: 1fr;
		}
	}

	/* ─── About / Founders ───────────────────────────────────── */
	.founders-layout {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 4rem;
		align-items: start;
	}
	.founders-col-left {
		display: flex;
		flex-direction: column;
	}
	.founders-col-right {
		display: flex;
		flex-direction: column;
		gap: 2rem;
		align-items: flex-start;
	}
	.founders-image-wrap {
		margin-bottom: 2rem;
	}
	.founders-image-wrap img {
		width: 100%;
		max-width: 400px;
		height: auto;
		display: block;
		border-radius: 12px;
	}
	.founders-avatars {
		display: flex;
		gap: 0.5rem;
		margin-bottom: 1.5rem;
	}
	.founder-avatar {
		width: 44px;
		height: 44px;
		border-radius: 50%;
		background: #000;
		color: #fff;
		font-size: 0.6875rem;
		font-weight: 700;
		letter-spacing: 0.02em;
		display: flex;
		align-items: center;
		justify-content: center;
	}
	.founders-names {
		font-size: 1.125rem;
		font-weight: 600;
		color: var(--text-1);
		margin-bottom: 0.25rem;
		letter-spacing: -0.02em;
	}
	.founders-title {
		font-size: 0.8125rem;
		color: var(--text-3);
		margin-bottom: 1.5rem;
		font-weight: 500;
	}
	.founders-body {
		font-size: 0.9375rem;
		color: var(--text-2);
		line-height: 1.75;
		max-width: 540px;
	}
	.founders-meta {
		display: flex;
		flex-direction: column;
		gap: 2rem;
		padding-top: 0.25rem;
	}
	.meta-label {
		font-size: 0.625rem;
		font-weight: 700;
		color: var(--text-3);
		text-transform: uppercase;
		letter-spacing: 0.08em;
		margin-bottom: 0.75rem;
	}
	.meta-pills {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
	}
	.meta-pill {
		font-size: 0.75rem;
		font-weight: 500;
		color: var(--text-2);
		background: var(--bg);
		border: 1px solid var(--border-mid);
		padding: 0.3125rem 0.75rem;
		border-radius: 20px;
	}
	.meta-stat-row {
		display: flex;
		gap: 2rem;
		padding-top: 1rem;
		border-top: 1px solid var(--border);
	}
	.stat-value {
		font-size: 1.75rem;
		font-weight: 700;
		color: var(--text-1);
		letter-spacing: -0.03em;
		line-height: 1;
		margin-bottom: 0.25rem;
	}
	.stat-label {
		font-size: 0.6875rem;
		color: var(--text-3);
		font-weight: 500;
	}

	/* ─── CTA section ────────────────────────────────────────── */
	.section--dark .section-inner {
		padding: 8rem 2rem;
		max-width: none;
		text-align: center;
	}
	.cta-eyebrow {
		font-size: 0.6875rem;
		font-weight: 600;
		color: rgba(255,255,255,0.3);
		text-transform: uppercase;
		letter-spacing: 0.1em;
		margin-bottom: 1.25rem;
	}
	.cta-heading {
		font-family: 'IBM Plex Sans', sans-serif;
		font-size: clamp(2rem, 5vw, 3rem);
		font-weight: 300;
		letter-spacing: -0.03em;
		color: #f5f5f5;
		line-height: 1.1;
		margin-bottom: 1.5rem;
		position: relative;
		cursor: default;
	}

	.cta-orbit {
		position: absolute;
		right: 5%;
		top: 50%;
		transform: translateY(-50%);
		width: 300px;
		height: 300px;
		pointer-events: none;
	}

	.orbit-track {
		position: relative;
		width: 100%;
		height: 100%;
		animation: orbit-spin 20s linear infinite;
	}

	.orbit {
		position: absolute;
		font-size: 0.5rem;
		color: #3b82f6;
	}

	.orbit-1 {
		top: 0;
		left: 50%;
		transform: translateX(-50%);
	}

	.orbit-2 {
		bottom: 20%;
		right: 10%;
	}

	.orbit-3 {
		top: 40%;
		left: 15%;
	}

	.orbit-center {
		position: absolute;
		top: 50%;
		left: 50%;
		transform: translate(-50%, -50%);
		width: 100px;
		height: 100px;
		border: 1px solid rgba(59, 130, 246, 0.2);
		border-radius: 50%;
		animation: orbit-spin 30s linear infinite reverse;
	}

	.orbit-center::after {
		content: '';
		position: absolute;
		top: 50%;
		left: 50%;
		transform: translate(-50%, -50%);
		width: 160px;
		height: 160px;
		border: 1px solid rgba(82, 39, 255, 0.15);
		border-radius: 50%;
	}

	@keyframes orbit-spin {
		from { transform: rotate(0deg); }
		to { transform: rotate(360deg); }
	}

	.cta-sub {
		font-size: 1rem;
		color: rgba(255,255,255,0.45);
		line-height: 1.7;
		max-width: 480px;
		margin: 0 auto 2.5rem;
	}
	.btn-primary-inv {
		display: inline-flex;
		align-items: center;
		background: #fff;
		color: #000;
		text-decoration: none;
		font-size: 0.9375rem;
		font-weight: 600;
		padding: 0.875rem 1.75rem;
		border-radius: 8px;
		border: 1px solid #fff;
		letter-spacing: -0.01em;
		transition: opacity 0.15s;
	}
	.btn-primary-inv:hover { opacity: 0.88; }

	/* ─── FAQs ───────────────────────────────────────────────── */
	#faqs { }
	.faqs-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 1rem;
		margin-top: 2rem;
	}
	.faq-item {
		background: #fff;
		border: 1px solid var(--border);
		border-radius: 8px;
		overflow: hidden;
	}
	.faq-question {
		width: 100%;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		padding: 1.25rem 1.5rem;
		background: none;
		border: none;
		cursor: pointer;
		text-align: left;
		font-family: 'IBM Plex Sans', sans-serif;
		font-size: 0.9375rem;
		font-weight: 500;
		color: var(--text-1);
		letter-spacing: -0.01em;
		line-height: 1.4;
		transition: background 0.15s;
	}
	.faq-question:hover {
		background: #fafafa;
	}
	.faq-question span:first-child {
		flex: 1;
	}
	.faq-icon {
		font-size: 1.25rem;
		color: var(--text-3);
		transition: transform 0.2s;
		flex-shrink: 0;
	}
	.faq-item.open .faq-icon {
		transform: rotate(45deg);
	}
	.faq-answer {
		max-height: 0;
		overflow: hidden;
		transition: max-height 0.3s ease;
	}
	.faq-item.open .faq-answer {
		max-height: 200px;
	}
	.faq-answer p {
		padding: 0 1.5rem 1.25rem;
		font-size: 0.8125rem;
		color: var(--text-2);
		line-height: 1.65;
	}
	@media (max-width: 768px) {
		.faqs-grid { grid-template-columns: 1fr; }
	}

	/* ─── Footer ─────────────────────────────────────────────── */
	.footer {
		position: relative;
		padding: 2rem 0;
	}
	.footer::before {
		content: '';
		position: absolute;
		top: 0;
		left: 50%;
		transform: translateX(-50%);
		width: min(var(--max-w), 100vw);
		height: 1px;
		background: var(--border);
	}
	.footer-inner {
		max-width: var(--max-w);
		margin: 0 auto;
		padding: 0 2rem;
		display: flex;
		align-items: center;
		justify-content: space-between;
		flex-wrap: wrap;
		gap: 1.5rem;
	}
	.footer-logo {
		display: flex;
		align-items: center;
	}
	.footer-logo img {
		height: 22px;
		width: auto;
	}
	.footer-policies {
		display: flex;
		align-items: center;
		gap: 0.5rem;
	}
	.footer-policies a {
		font-size: 0.8125rem;
		color: var(--text-2);
		text-decoration: none;
		transition: color 0.15s;
	}
	.footer-policies a:hover { color: var(--text-1); }
	.footer-sep {
		color: var(--text-3);
		font-size: 0.75rem;
	}
	.footer-copy {
		font-size: 0.75rem;
		color: var(--text-3);
	}

	/* ─── Product Mockup ─────────────────────────────────────── */
	.mockup-section {
		position: relative;
		background: #f5f5f5;
	}
	.mockup-section::after {
		content: '';
		position: absolute;
		bottom: 0;
		left: 50%;
		transform: translateX(-50%);
		width: min(var(--max-w), 100vw);
		height: 1px;
		background: var(--border);
	}
	.mockup-inner {
		max-width: var(--max-w);
		margin: 0 auto;
		padding: 3.5rem 2rem 0;
	}
	.mockup-browser {
		border-radius: 10px 10px 0 0;
		overflow: hidden;
		border: 1px solid rgba(0,0,0,0.10);
		border-bottom: none;
		box-shadow: 0 8px 40px rgba(0,0,0,0.08), 0 1px 4px rgba(0,0,0,0.04);
	}
	.browser-chrome {
		background: #e8e8e8;
		padding: 0 1rem;
		height: 36px;
		display: flex;
		align-items: center;
		gap: 0.75rem;
		border-bottom: 1px solid rgba(0,0,0,0.08);
	}
	.browser-dots {
		display: flex;
		gap: 5px;
		flex-shrink: 0;
	}
	.browser-dots span {
		width: 10px;
		height: 10px;
		border-radius: 50%;
	}
	.dot-red   { background: #ff5f57; }
	.dot-yellow{ background: #febc2e; }
	.dot-green { background: #28c840; }
	.browser-url {
		flex: 1;
		background: rgba(255,255,255,0.7);
		border: 1px solid rgba(0,0,0,0.08);
		border-radius: 5px;
		height: 22px;
		line-height: 22px;
		text-align: center;
		font-size: 0.6875rem;
		color: rgba(0,0,0,0.4);
		font-family: 'Inter', monospace;
		max-width: 320px;
		margin: 0 auto;
	}
	.browser-body {
		display: flex;
		height: 420px;
		background: #fff;
		overflow: hidden;
	}

	/* Sidebar */
	.app-sidebar {
		width: 172px;
		flex-shrink: 0;
		background: #fafafa;
		border-right: 1px solid rgba(0,0,0,0.07);
		padding: 1rem 0.75rem;
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}
	.sidebar-logo {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		font-size: 0.8125rem;
		font-weight: 600;
		color: #000;
		padding: 0 0.375rem;
	}
	.sidebar-items {
		display: flex;
		flex-direction: column;
		gap: 2px;
	}
	.sidebar-item {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		font-size: 0.75rem;
		color: rgba(0,0,0,0.4);
		padding: 0.4375rem 0.5rem;
		border-radius: 5px;
		cursor: pointer;
		border: none;
		background: none;
		width: 100%;
		text-align: left;
		font-family: inherit;
		transition: background 0.12s, color 0.12s;
	}
	.sidebar-item:hover { background: rgba(0,0,0,0.04); color: rgba(0,0,0,0.7); }
	.sidebar-item.active {
		background: rgba(0,0,0,0.06);
		color: #000;
		font-weight: 500;
	}

	/* Main canvas */
	.app-canvas {
		flex: 1;
		display: flex;
		flex-direction: column;
		overflow: hidden;
	}
	.app-topbar {
		height: 44px;
		border-bottom: 1px solid rgba(0,0,0,0.07);
