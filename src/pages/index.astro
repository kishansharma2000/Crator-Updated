---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Crator | Applied AI Company | Singapore">

	<!-- Continuous vertical rails -->
	<div class="page-rails" aria-hidden="true"></div>

	<!-- Navigation -->
	<Nav active="home" />

	<!-- Hero -->
	<section class="hero">
		<div class="hero-inner">
			<h1>We are the <span class="gradient-text">AI Partner</span> you need</h1>
			<p class="hero-sub">We find where AI moves the needle in your business, build the systems, and run them for you.</p>
			<div class="hero-actions">
				<a href="/book-a-demo" class="btn-primary"><span>Book a free strategy call</span></a>
				<a href="#work" class="btn-ghost">See our work</a>
			</div>
		</div>
		
		<!-- Product Mockup in Hero -->
		<div class="hero-mockup">
			<div class="mockup-browser hero-mockup">
				<div class="browser-chrome">
					<div class="browser-dots">
						<span class="dot-red"></span><span class="dot-yellow"></span><span class="dot-green"></span>
					</div>
					<div class="browser-url">app.cratorlabs.ai/dashboard</div>
				</div>
				<div class="browser-body">
					<div class="app-sidebar">
						<div class="sidebar-logo">
							<svg width="16" height="16" viewBox="0 0 32 32" fill="none"><rect width="32" height="32" rx="5" fill="#000"/><path d="M9 9h14v2H11v10h2V11h2v10h2V11h2v10h2V9H9v12H7v2h16v-2H9V9z" fill="#fff"/></svg>
							<span>Crator</span>
						</div>
						<div class="sidebar-items">
							<button class="sidebar-item active" data-view="overview">
								<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
								Overview
							</button>
							<button class="sidebar-item" data-view="agents">
								<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
								Agents
							</button>
							<button class="sidebar-item" data-view="analytics">
								<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
								Analytics
							</button>
							<button class="sidebar-item" data-view="integrations">
								<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14M4.93 4.93a10 10 0 0 0 0 14.14"/></svg>
								Integrations
							</button>
						</div>
					</div>
					<div class="app-canvas">
						<div class="app-topbar">
							<span class="app-page-title" id="app-title">Operations Overview</span>
							<div class="app-topbar-right">
								<div class="app-badge">Live</div>
								<div class="app-avatar"></div>
							</div>
						</div>
						<div class="app-view" data-panel="overview">
							<div class="app-content">
								<div class="kpi-row">
									<div class="kpi-card">
										<p class="kpi-value">$14,820</p>
										<p class="kpi-label">Revenue Today</p>
										<p class="kpi-delta up">+12.4%</p>
									</div>
									<div class="kpi-card">
										<p class="kpi-value">2,847</p>
										<p class="kpi-label">Active Users</p>
										<p class="kpi-delta up">+8.2%</p>
									</div>
									<div class="kpi-card">
										<p class="kpi-value">156</p>
										<p class="kpi-label">Deals Pipeline</p>
										<p class="kpi-delta up">+23.1%</p>
									</div>
									<div class="kpi-card">
										<p class="kpi-value">98.2%</p>
										<p class="kpi-label">Task Success</p>
										<p class="kpi-delta up">+2.1%</p>
									</div>
								</div>
								<div class="chart-area">
									<div class="chart-header">
										<span class="chart-title">Revenue Trend</span>
										<span class="chart-period">Last 30 days</span>
									</div>
									<div class="chart-bars">
										<div class="bar" style="height:38%"></div>
										<div class="bar" style="height:52%"></div>
										<div class="bar" style="height:45%"></div>
										<div class="bar" style="height:70%"></div>
										<div class="bar" style="height:60%"></div>
										<div class="bar" style="height:80%"></div>
										<div class="bar" style="height:65%"></div>
										<div class="bar" style="height:75%"></div>
										<div class="bar" style="height:90%"></div>
										<div class="bar" style="height:72%"></div>
										<div class="bar" style="height:85%"></div>
										<div class="bar" style="height:95%"></div>
										<div class="bar" style="height:88%"></div>
										<div class="bar hi" style="height:100%"></div>
									</div>
								</div>
								<div class="feed-area">
									<div class="feed-header">Recent Agent Activity</div>
									<div class="feed-items">
										<div class="feed-item">
											<div class="feed-dot green"></div>
											<div><p class="feed-action">Sales Agent closed deal</p><p class="feed-time">2 min ago</p></div>
										</div>
										<div class="feed-item">
											<div class="feed-dot blue"></div>
											<div><p class="feed-action">Support ticket resolved</p><p class="feed-time">5 min ago</p></div>
										</div>
										<div class="feed-item">
											<div class="feed-dot amber"></div>
											<div><p class="feed-action">Inventory alert triggered</p><p class="feed-time">11 min ago</p></div>
										</div>
										<div class="feed-item">
											<div class="feed-dot green"></div>
											<div><p class="feed-action">Invoice auto-generated</p><p class="feed-time">18 min ago</p></div>
										</div>
									</div>
								</div>
							</div>
						</div>
						<div class="app-view hidden" data-panel="agents">
							<div class="app-content">
								<div class="agents-list">
									<div class="agent-row">
										<div class="agent-avatar"></div>
										<div class="agent-info">
											<p class="agent-name">Sales Agent</p>
											<p class="agent-status">Active • 847 runs</p>
										</div>
										<div class="agent-status-dot green"></div>
									</div>
									<div class="agent-row">
										<div class="agent-avatar"></div>
										<div class="agent-info">
											<p class="agent-name">Support Agent</p>
											<p class="agent-status">Active • 623 runs</p>
										</div>
										<div class="agent-status-dot green"></div>
									</div>
									<div class="agent-row">
										<div class="agent-avatar"></div>
										<div class="agent-info">
											<p class="agent-name">Operations Agent</p>
											<p class="agent-status">Active • 412 runs</p>
										</div>
										<div class="agent-status-dot green"></div>
									</div>
								</div>
							</div>
						</div>
						<div class="app-view hidden" data-panel="analytics">
							<div class="app-content">
								<div class="analytics-summary">
									<div class="stat-card">
										<p class="stat-value">12.4K</p>
										<p class="stat-label">API Calls Today</p>
									</div>
									<div class="stat-card">
										<p class="stat-value">1.2s</p>
										<p class="stat-label">Avg Response</p>
									</div>
									<div class="stat-card">
										<p class="stat-value">99.8%</p>
										<p class="stat-label">Uptime</p>
									</div>
								</div>
							</div>
						</div>
						<div class="app-view hidden" data-panel="integrations">
							<div class="app-content">
								<div class="integrations-grid">
									<div class="integration-card connected">
										<div class="int-icon" style="background:#00D2FF;color:#fff">SF</div>
										<div class="int-info">
											<p class="int-name">Salesforce</p>
											<p class="int-status connected-txt">Connected</p>
										</div>
									</div>
									<div class="integration-card connected">
										<div class="int-icon" style="background:#4A154B;color:#fff">S3</div>
										<div class="int-info">
											<p class="int-name">Slack</p>
											<p class="int-status connected-txt">Connected</p>
										</div>
									</div>
									<div class="integration-card connected">
										<div class="int-icon" style="background:#2D2D2D;color:#fff">G4</div>
										<div class="int-info">
											<p class="int-name">Gmail</p>
											<p class="int-status connected-txt">Connected</p>
										</div>
									</div>
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
</section>

	<!-- Services -->
	<section class="section section--alt" id="services">
		<div class="section-inner">
			<div class="section-header">
				<p class="section-tag">Services</p>
				<h2 class="section-heading">
					We help you make your<br>business AI-native.
				</h2>
				<p class="section-sub">
					From figuring out use-cases, to figuring out build v/s buy and building for you. We handle the entire stack so you can focus on running your business.
				</p>
			</div>

			<div class="phases">
				<div class="phase-item">
					<div class="phase-top">
						<h3>Audit</h3>
						<span class="phase-when">Week 1–2</span>
					</div>
					<p>We map your workflows and find the 5% of opportunities actually worth building. You get a clear roadmap: what to automate, what to build, what to buy off the shelf.</p>
				</div>
				<div class="phase-item">
					<div class="phase-top">
						<h3>Build</h3>
						<span class="phase-when">Week 2–4</span>
					</div>
					<p>We embed within your team and ship AI systems that fit your existing workflows. Custom agents, dashboards, and integrations, built right so they work from day one.</p>
				</div>
				<div class="phase-item">
					<div class="phase-top">
						<h3>Run</h3>
						<span class="phase-when">Ongoing</span>
					</div>
					<p>We deploy, monitor, and manage. If something breaks, we fix it. If something can be better, we improve it. You get results, not a handoff.</p>
				</div>
			</div>
		</div>
	</section>

	<!-- Trusted By Marquee -->
	<div class="trusted-by-section">
		<div class="trusted-by-inner">
			<span class="trusted-by-label">Trusted by</span>
			<div class="trusted-by-content">
				<!-- 4 sets of logos in one flat track; animation scrolls -50% = 2 sets seamlessly -->
				<div class="trusted-by-track">
					<!-- Set 1 -->
					<div class="logo-item"><img src="https://www.cratorlabs.ai/_next/image?url=%2Flogos%2Fflow-coffee.avif&w=128&q=75" alt="Flow Coffee" class="logo-black" /></div>
					<div class="logo-item"><img src="https://www.cratorlabs.ai/_next/image?url=%2Flogos%2Fkinetic.png&w=128&q=75" alt="Kinetic Group" class="logo-black" /></div>
					<div class="logo-item"><img src="https://www.cratorlabs.ai/logos/lm-trading.svg" alt="LM Trading" class="logo-black" /></div>
					<div class="logo-item"><img src="https://wp.logos-download.com/wp-content/uploads/2022/11/Nanyang_Technological_University_Logo.png?dl" alt="NTU" class="logo-black" /></div>
					<!-- Set 2 -->
					<div class="logo-item" aria-hidden="true"><img src="https://www.cratorlabs.ai/_next/image?url=%2Flogos%2Fflow-coffee.avif&w=128&q=75" alt="" class="logo-black" /></div>
					<div class="logo-item" aria-hidden="true"><img src="https://www.cratorlabs.ai/_next/image?url=%2Flogos%2Fkinetic.png&w=128&q=75" alt="" class="logo-black" /></div>
					<div class="logo-item" aria-hidden="true"><img src="https://www.cratorlabs.ai/logos/lm-trading.svg" alt="" class="logo-black" /></div>
					<div class="logo-item" aria-hidden="true"><img src="https://wp.logos-download.com/wp-content/uploads/2022/11/Nanyang_Technological_University_Logo.png?dl" alt="" class="logo-black" /></div>
					<!-- Set 3 -->
					<div class="logo-item" aria-hidden="true"><img src="https://www.cratorlabs.ai/_next/image?url=%2Flogos%2Fflow-coffee.avif&w=128&q=75" alt="" class="logo-black" /></div>
					<div class="logo-item" aria-hidden="true"><img src="https://www.cratorlabs.ai/_next/image?url=%2Flogos%2Fkinetic.png&w=128&q=75" alt="" class="logo-black" /></div>
					<div class="logo-item" aria-hidden="true"><img src="https://www.cratorlabs.ai/logos/lm-trading.svg" alt="" class="logo-black" /></div>
					<div class="logo-item" aria-hidden="true"><img src="https://wp.logos-download.com/wp-content/uploads/2022/11/Nanyang_Technological_University_Logo.png?dl" alt="" class="logo-black" /></div>
					<!-- Set 4 (mirror of set 3 — seamless at the -50% reset point) -->
					<div class="logo-item" aria-hidden="true"><img src="https://www.cratorlabs.ai/_next/image?url=%2Flogos%2Fflow-coffee.avif&w=128&q=75" alt="" class="logo-black" /></div>
					<div class="logo-item" aria-hidden="true"><img src="https://www.cratorlabs.ai/_next/image?url=%2Flogos%2Fkinetic.png&w=128&q=75" alt="" class="logo-black" /></div>
					<div class="logo-item" aria-hidden="true"><img src="https://www.cratorlabs.ai/logos/lm-trading.svg" alt="" class="logo-black" /></div>
					<div class="logo-item" aria-hidden="true"><img src="https://wp.logos-download.com/wp-content/uploads/2022/11/Nanyang_Technological_University_Logo.png?dl" alt="" class="logo-black" /></div>
				</div>
			</div>
		</div>
	</div>


<!-- AI Agents -->
	<section class="section" id="agents">
		<div class="section-inner">
			<div class="section-header">
				<p class="section-tag">AI Agents</p>
				<h2 class="section-heading">
					We build AI agents that<br>run your operations.
				</h2>
				<p class="section-sub">
					Agents that plug into Telegram, WhatsApp, and Slack and handle tasks autonomously. Here's what that looks like in practice.
				</p>
			</div>

			<div class="agent-layout">
				<a href="/portfolio/flow-coffee-sales-agent" class="agent-card">
					<div class="agent-icon"><i class="ph-duotone ph-currency-dollar-simple"></i></div>
					<div class="agent-content">
						<h3>Sales Agent</h3>
						<p>AI-powered sales pipeline management, lead tracking, and location prospecting — all accessible via Telegram. Maintains CRM, flags duplicates, and recommends optimal new locations.</p>
					</div>
					<div class="agent-tags">
						<span>Telegram</span>
						<span>CRM</span>
						<span>Sales</span>
					</div>
				</a>
				<a href="/portfolio/flow-coffee-operations-agent" class="agent-card">
					<div class="agent-icon"><i class="ph-duotone ph-gear-six"></i></div>
					<div class="agent-content">
						<h3>Operations Agent</h3>
						<p>Operational intelligence across all machines — scheduled reports, anomaly detection, ingredient forecasting, maintenance dispatch, payment matching, and KPI tracking. All via Telegram.</p>
					</div>
					<div class="agent-tags">
						<span>Operations</span>
						<span>Analytics</span>
						<span>Forecasting</span>
					</div>
				</a>
				<a href="/portfolio/flow-coffee-support-agent" class="agent-card">
					<div class="agent-icon"><i class="ph-duotone ph-headset"></i></div>
					<div class="agent-content">
						<h3>Support Agent</h3>
						<p>Automated customer support operations — reads WhatsApp chat logs, classifies incidents, logs everything to a structured database, and issues redemption codes on command.</p>
					</div>
					<div class="agent-tags">
						<span>Support</span>
						<span>WhatsApp</span>
						<span>Incident Logging</span>
					</div>
				</a>
				<a href="/portfolio/hoursense-legal-billing" class="agent-card">
					<div class="agent-badge">Top-5 Indian Law Firm</div>
					<div class="agent-icon"><i class="ph-duotone ph-scales"></i></div>
					<div class="agent-content">
						<h3>HourSense — Legal Billing AI</h3>
						<p>AI-powered time tracking that automates billing for lawyers. Validated via a POC with one of India's largest law firms.</p>
					</div>
					<div class="agent-tags">
						<span>Legal AI</span>
						<span>LLM</span>
						<span>SaaS</span>
					</div>
				</a>
			</div>
		</div>
	</section>

<!-- Custom Software -->
	<section class="section section--alt" id="software">
		<div class="section-inner section-inner--sticky">
			<div class="section-sticky">
				<p class="section-tag">Custom Software</p>
				<h2 class="section-heading">
					We build the software your business runs on.
				</h2>
				<p class="section-sub">
					We take your messy spreadsheets and manual processes and turn them into production software in weeks. Here's what we've shipped.
				</p>
			</div>

			<div class="work-cards-scroll">
				<a href="/portfolio/flow-coffee-web-app" class="work-card">
					<div class="work-card-top">
						<h3>AI-Native ERP for Operations</h3>
						<p>Full-stack operations dashboard consolidating machine data, sales analytics, maintenance scheduling, inventory forecasting, anomaly detection, and CRM — replacing Google Sheets entirely.</p>
					</div>
					<div class="work-card-footer">
						<div class="work-card-tags">
							<span>Dashboard</span>
							<span>Analytics</span>
							<span>CRM</span>
						</div>
						<span class="work-card-arrow">→</span>
					</div>
				</a>
				<a href="/portfolio/garment-supply-chain-erp" class="work-card">
					<div class="work-card-top">
						<h3>Garment Supply Chain ERP</h3>
						<p>Centralised supply chain and inventory management across 6 independent manufacturing units. Replaced 5 manual spreadsheet workers with a single system.</p>
					</div>
					<div class="work-card-footer">
						<div class="work-card-tags">
							<span>ERP</span>
							<span>Automation</span>
							<span>Supply Chain</span>
						</div>
						<span class="work-card-arrow">→</span>
					</div>
				</a>
				<a href="/portfolio/gst-e-invoicing" class="work-card">
					<div class="work-card-top">
						<h3>GST E-Invoicing System</h3>
						<p>One-click IRN + QR code generation for government-compliant invoices. Eliminated the need for a costly Zoho migration.</p>
					</div>
					<div class="work-card-footer">
						<div class="work-card-tags">
							<span>Document AI</span>
							<span>Compliance</span>
							<span>Python</span>
						</div>
						<span class="work-card-arrow">→</span>
					</div>
				</a>
				<a href="/portfolio/rice-machine-installment-tracker" class="work-card">
					<div class="work-card-top">
						<h3>Rice Machine Installment Tracker</h3>
						<p>Installment tracking for high-value machines sold on 3–7 year payment plans across hundreds of clients.</p>
					</div>
					<div class="work-card-footer">
						<div class="work-card-tags">
							<span>Payments</span>
							<span>CRM</span>
							<span>Software</span>
						</div>
						<span class="work-card-arrow">→</span>
					</div>
				</a>
				<a href="/portfolio/askwaai" class="work-card">
					<div class="work-card-top">
						<h3>AskWaai — Writing Feedback AI</h3>
						<p>AI writing feedback platform for NTU's mandatory CC0001 course. Deployed to thousands of students.</p>
					</div>
					<div class="work-card-footer">
						<div class="work-card-tags">
							<span>LLM</span>
							<span>Education</span>
							<span>Next.js</span>
						</div>
						<span class="work-card-arrow">→</span>
					</div>
				</a>
			</div>
		</div>
	</section>

	<!-- 04 / About -->
	<section class="section" id="about">
		<div class="section-inner">
			<p class="section-tag">About</p>
			<h2 class="section-heading section-heading--large" style="margin-bottom: 3rem;">
				Built by founders<br>who've shipped.
			</h2>

			<div class="founders-layout">
				<div class="founders-col-left">
					<div class="founders-image-wrap">
						<img src="/images/shrivardhan.webp" alt="Shrivardhan Goenka" width="500" height="376" loading="lazy" />
					</div>
					<p class="founders-names">Yajat Gulati &amp; Shrivardhan Goenka</p>
					<p class="founders-title">Co-Founders, Crator Labs</p>
				</div>
				<div class="founders-col-right">
					<p class="founders-body">
						We're a team of young, AI-native engineers based out of Singapore. We've spent the last 4 years building AI systems for real businesses: products deployed at NTU Singapore, systems built for companies doing $10M+ in revenue, a top-5 Indian law firm, and a James Dyson Award. We're ex-researchers at NTU (top 10 globally for Computer Science) and alumni of SAP Singapore.
					</p>
					<div class="founders-meta">
						<div class="meta-block">
							<p class="meta-label">Researchers at</p>
							<div class="meta-pills">
								<span class="meta-pill">NTU Singapore</span>
								<span class="meta-pill">SAP Singapore</span>
							</div>
						</div>
						<div class="meta-block">
							<p class="meta-label">Recognised by</p>
							<div class="meta-pills">
								<span class="meta-pill">James Dyson Award</span>
								<span class="meta-pill">Top-5 Indian Law Firm</span>
								<span class="meta-pill">$10M+ Revenue Co.</span>
							</div>
						</div>
						<div class="meta-stat-row">
							<div class="meta-stat">
								<p class="stat-value">4+</p>
								<p class="stat-label">Years building AI</p>
							</div>
							<div class="meta-stat">
								<p class="stat-value">12+</p>
								<p class="stat-label">Products shipped</p>
							</div>
							<div class="meta-stat">
								<p class="stat-value">3</p>
								<p class="stat-label">Countries served</p>
							</div>
						</div>
					</div>
