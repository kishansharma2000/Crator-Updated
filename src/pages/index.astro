		grid-template-columns: repeat(3, 1fr);
		gap: 1.25rem;
	}
	.phase-item {
		background: #fff;
		border: 1px solid var(--border);
		border-radius: 12px;
		padding: 2.25rem 2rem;
		display: flex;
		flex-direction: column;
		gap: 1rem;
		transition: box-shadow 0.2s, transform 0.2s;
	}
	.phase-item:hover {
		box-shadow: 0 8px 32px rgba(0,0,0,0.07);
		transform: translateY(-2px);
	}
	.phase-top {
		display: flex;
		align-items: center;
		justify-content: space-between;
	}
	.phase-num {
		display: none;
	}
	.phase-when {
		font-size: 0.625rem;
		color: var(--text-3);
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		border: 1px solid var(--border);
		padding: 0.1875rem 0.5rem;
		border-radius: 20px;
	}
	.phase-item h3 {
		font-size: 1.375rem;
		font-weight: 600;
		color: var(--text-1);
		letter-spacing: -0.02em;
		line-height: 1.2;
	}
	.phase-item p {
		font-size: 0.875rem;
		color: var(--text-2);
		line-height: 1.7;
	}

	/* ─── Work grid ──────────────────────────────────────────── */
	.work-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 1px;
		background: var(--border);
		border: 1px solid var(--border);
		border-radius: 12px;
		overflow: hidden;
	}
	.work-grid--3 { grid-template-columns: repeat(3, 1fr); }
	.work-card {
		background: var(--bg);
		padding: 2rem;
		text-decoration: none;
		color: inherit;
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
		transition: background 0.15s;
		position: relative;
	}
	.work-card::before {
		content: '';
		position: absolute;
		top: 0; left: 0; right: 0;
		height: 2px;
		background: #000;
		transform: scaleX(0);
		transform-origin: left;
		transition: transform 0.25s ease;
	}
	.work-card:hover { background: #fafafa; }
	.work-card:hover::before { transform: scaleX(1); }
	.work-card:hover .work-card-arrow { opacity: 1; transform: translateX(0); }
	.work-card--featured { background: #fafafa; }
	.work-card-index {
		/* removed */
	}
	.work-card-client {
		font-size: 0.625rem;
		font-weight: 600;
		color: var(--text-3);
		text-transform: uppercase;
		letter-spacing: 0.06em;
		margin-bottom: 0.375rem;
	}
	.work-card-top { flex: 1; }
	.work-card-top h3 {
		font-size: 1.0625rem;
		font-weight: 600;
		color: var(--text-1);
		margin-bottom: 0.625rem;
		letter-spacing: -0.015em;
		line-height: 1.3;
	}
	.work-card-top p {
		font-size: 0.8125rem;
		color: var(--text-2);
		line-height: 1.65;
	}
	.work-card-footer {
		display: flex;
		align-items: center;
		justify-content: space-between;
	}
	.work-card-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.375rem;
	}
	.work-card-tags span {
		font-size: 0.5625rem;
		font-weight: 600;
		color: var(--text-3);
		background: rgba(0,0,0,0.04);
		border: 1px solid var(--border);
		padding: 0.1875rem 0.5rem;
		border-radius: 3px;
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}
	.work-card-arrow {
		font-size: 1rem;
		color: var(--text-1);
		opacity: 0;
		transform: translateX(-6px);
		transition: opacity 0.2s, transform 0.2s;
		flex-shrink: 0;
	}

	/* ─── About / Founders ───────────────────────────────────── */
	.founders-layout {
		display: grid;
		grid-template-columns: 1fr 340px;
		gap: 5rem;
		align-items: start;
	}
	.founders-avatars {
		display: flex;
		gap: 0.5rem;
		margin-bottom: 1.5rem;
	}
	.founder-avatar {
		width: 44px;
		height: 44px;
		border-radius: 50%;
		background: #000;
		color: #fff;
		font-size: 0.6875rem;
		font-weight: 700;
		letter-spacing: 0.02em;
		display: flex;
		align-items: center;
		justify-content: center;
	}
	.founders-names {
		font-size: 1.125rem;
		font-weight: 600;
		color: var(--text-1);
		margin-bottom: 0.25rem;
		letter-spacing: -0.02em;
	}
	.founders-title {
		font-size: 0.8125rem;
		color: var(--text-3);
		margin-bottom: 1.5rem;
		font-weight: 500;
	}
	.founders-body {
		font-size: 0.9375rem;
		color: var(--text-2);
		line-height: 1.75;
		max-width: 540px;
	}
	.founders-meta {
		display: flex;
		flex-direction: column;
		gap: 2rem;
		padding-top: 0.25rem;
	}
	.meta-label {
		font-size: 0.625rem;
		font-weight: 700;
		color: var(--text-3);
		text-transform: uppercase;
		letter-spacing: 0.08em;
		margin-bottom: 0.75rem;
	}
	.meta-pills {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
	}
	.meta-pill {
		font-size: 0.75rem;
		font-weight: 500;
		color: var(--text-2);
		background: var(--bg);
		border: 1px solid var(--border-mid);
		padding: 0.3125rem 0.75rem;
		border-radius: 20px;
	}
	.meta-stat-row {
		display: flex;
		gap: 2rem;
		padding-top: 1rem;
		border-top: 1px solid var(--border);
	}
	.stat-value {
		font-size: 1.75rem;
		font-weight: 700;
		color: var(--text-1);
		letter-spacing: -0.03em;
		line-height: 1;
		margin-bottom: 0.25rem;
	}
	.stat-label {
		font-size: 0.6875rem;
		color: var(--text-3);
		font-weight: 500;
	}

	/* ─── CTA section ────────────────────────────────────────── */
	.section--dark .section-inner {
		padding: 8rem 2rem;
		max-width: none;
	}
	.cta-eyebrow {
		font-size: 0.6875rem;
		font-weight: 600;
		color: rgba(255,255,255,0.3);
		text-transform: uppercase;
		letter-spacing: 0.1em;
		margin-bottom: 1.25rem;
	}
	.cta-heading {
		font-family: 'IBM Plex Sans', sans-serif;
		font-size: clamp(2rem, 5vw, 3rem);
		font-weight: 300;
		letter-spacing: -0.03em;
		color: #f5f5f5;
		line-height: 1.1;
		margin-bottom: 1.5rem;
		position: relative;
		cursor: default;
	}

	.cta-orbit {
		position: absolute;
		right: 5%;
		top: 50%;
		transform: translateY(-50%);
		width: 300px;
		height: 300px;
		pointer-events: none;
	}

	.orbit-track {
		position: relative;
		width: 100%;
		height: 100%;
		animation: orbit-spin 20s linear infinite;
	}

	.orbit {
		position: absolute;
		font-size: 0.5rem;
		color: #3b82f6;
	}

	.orbit-1 {
		top: 0;
		left: 50%;
		transform: translateX(-50%);
	}

	.orbit-2 {
		bottom: 20%;
		right: 10%;
	}

	.orbit-3 {
		top: 40%;
		left: 15%;
	}

	.orbit-center {
		position: absolute;
		top: 50%;
		left: 50%;
		transform: translate(-50%, -50%);
		width: 100px;
		height: 100px;
		border: 1px solid rgba(59, 130, 246, 0.2);
		border-radius: 50%;
		animation: orbit-spin 30s linear infinite reverse;
	}

	.orbit-center::after {
		content: '';
		position: absolute;
		top: 50%;
		left: 50%;
		transform: translate(-50%, -50%);
		width: 160px;
		height: 160px;
		border: 1px solid rgba(82, 39, 255, 0.15);
		border-radius: 50%;
	}

	@keyframes orbit-spin {
		from { transform: rotate(0deg); }
		to { transform: rotate(360deg); }
	}

	.cta-sub {
		font-size: 1rem;
		color: rgba(255,255,255,0.45);
		line-height: 1.7;
		max-width: 440px;
		margin-bottom: 2.5rem;
	}
	.btn-primary-inv {
		display: inline-flex;
		align-items: center;
		background: #fff;
		color: #000;
		text-decoration: none;
		font-size: 0.9375rem;
		font-weight: 600;
		padding: 0.875rem 1.75rem;
		border-radius: 8px;
		border: 1px solid #fff;
		letter-spacing: -0.01em;
		transition: opacity 0.15s;
	}
	.btn-primary-inv:hover { opacity: 0.88; }

	/* ─── Footer ─────────────────────────────────────────────── */
	.footer {
		position: relative;
		padding: 1.75rem 2rem;
	}
	.footer::before {
		content: '';
		position: absolute;
		top: 0;
		left: 50%;
		transform: translateX(-50%);
		width: min(var(--max-w), 100vw);
		height: 1px;
		background: var(--border);
	}
	.footer-inner {
		max-width: var(--max-w);
		margin: 0 auto;
		display: flex;
		align-items: center;
		gap: 2rem;
		flex-wrap: wrap;
	}
	.footer-logo {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		font-size: 0.875rem;
		font-weight: 600;
		color: var(--text-1);
	}
	.footer-links {
		display: flex;
		gap: 1.5rem;
		flex: 1;
	}
	.footer-links a {
		font-size: 0.8125rem;
		color: var(--text-2);
		text-decoration: none;
		transition: color 0.15s;
	}
	.footer-links a:hover { color: var(--text-1); }
	.footer-copy {
		font-size: 0.75rem;
		color: var(--text-3);
		margin-left: auto;
	}

	/* ─── Product Mockup ─────────────────────────────────────── */
	.mockup-section {
		position: relative;
		background: #f5f5f5;
	}
	.mockup-section::after {
		content: '';
		position: absolute;
		bottom: 0;
		left: 50%;
		transform: translateX(-50%);
		width: min(var(--max-w), 100vw);
		height: 1px;
		background: var(--border);
	}
	.mockup-inner {
		max-width: var(--max-w);
		margin: 0 auto;
		padding: 3.5rem 2rem 0;
	}
	.mockup-browser {
		border-radius: 10px 10px 0 0;
		overflow: hidden;
		border: 1px solid rgba(0,0,0,0.10);
		border-bottom: none;
		box-shadow: 0 8px 40px rgba(0,0,0,0.08), 0 1px 4px rgba(0,0,0,0.04);
	}
	.browser-chrome {
		background: #e8e8e8;
		padding: 0 1rem;
		height: 36px;
		display: flex;
		align-items: center;
		gap: 0.75rem;
		border-bottom: 1px solid rgba(0,0,0,0.08);
	}
	.browser-dots {
		display: flex;
		gap: 5px;
		flex-shrink: 0;
	}
	.browser-dots span {
		width: 10px;
		height: 10px;
		border-radius: 50%;
	}
	.dot-red   { background: #ff5f57; }
	.dot-yellow{ background: #febc2e; }
	.dot-green { background: #28c840; }
	.browser-url {
		flex: 1;
		background: rgba(255,255,255,0.7);
		border: 1px solid rgba(0,0,0,0.08);
		border-radius: 5px;
		height: 22px;
		line-height: 22px;
		text-align: center;
		font-size: 0.6875rem;
		color: rgba(0,0,0,0.4);
		font-family: 'Inter', monospace;
		max-width: 320px;
		margin: 0 auto;
	}
	.browser-body {
		display: flex;
		height: 420px;
		background: #fff;
		overflow: hidden;
	}

	/* Sidebar */
	.app-sidebar {
		width: 172px;
		flex-shrink: 0;
		background: #fafafa;
		border-right: 1px solid rgba(0,0,0,0.07);
		padding: 1rem 0.75rem;
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}
	.sidebar-logo {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		font-size: 0.8125rem;
		font-weight: 600;
		color: #000;
		padding: 0 0.375rem;
	}
	.sidebar-items {
		display: flex;
		flex-direction: column;
		gap: 2px;
	}
	.sidebar-item {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		font-size: 0.75rem;
		color: rgba(0,0,0,0.4);
		padding: 0.4375rem 0.5rem;
		border-radius: 5px;
		cursor: pointer;
		border: none;
		background: none;
		width: 100%;
		text-align: left;
		font-family: inherit;
		transition: background 0.12s, color 0.12s;
	}
	.sidebar-item:hover { background: rgba(0,0,0,0.04); color: rgba(0,0,0,0.7); }
	.sidebar-item.active {
		background: rgba(0,0,0,0.06);
		color: #000;
		font-weight: 500;
	}

	/* Main canvas */
	.app-canvas {
		flex: 1;
		display: flex;
		flex-direction: column;
		overflow: hidden;
	}
	.app-topbar {
		height: 44px;
		border-bottom: 1px solid rgba(0,0,0,0.07);
		padding: 0 1.5rem;
		display: flex;
		align-items: center;
		justify-content: space-between;
		flex-shrink: 0;
	}
	.app-page-title {
		font-size: 0.8125rem;
		font-weight: 600;
		color: #000;
	}
	.app-topbar-right {
		display: flex;
		align-items: center;
		gap: 0.75rem;
	}
	.app-badge {
		font-size: 0.625rem;
		font-weight: 600;
		color: #16a34a;
		background: rgba(22,163,74,0.08);
		border: 1px solid rgba(22,163,74,0.18);
		padding: 0.1875rem 0.5rem;
		border-radius: 20px;
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}
	.app-avatar {
		width: 24px;
		height: 24px;
		border-radius: 50%;
		background: rgba(0,0,0,0.1);
	}

	/* Views */
	.app-view { flex: 1; display: flex; flex-direction: column; overflow: hidden; }
	.app-view.hidden { display: none; }

	/* App content */
	.app-content {
		flex: 1;
		overflow: hidden;
		padding: 1.25rem 1.5rem;
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	/* KPI */
	.kpi-row {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: 0.75rem;
	}
	.kpi-card {
		background: #fff;
		border: 1px solid rgba(0,0,0,0.08);
		border-radius: 8px;
		padding: 1rem;
	}
	.kpi-label {
		font-size: 0.625rem;
		color: rgba(0,0,0,0.4);
		font-weight: 500;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		margin-bottom: 0.375rem;
	}
	.kpi-value {
		font-size: 1.375rem;
		font-weight: 600;
		color: #000;
		letter-spacing: -0.02em;
		line-height: 1;
		margin-bottom: 0.375rem;
	}
	.kpi-delta { font-size: 0.625rem; font-weight: 500; }
	.kpi-delta.up { color: #16a34a; }

	/* Bottom row */
	.bottom-row {
		display: grid;
		grid-template-columns: 1fr 240px;
		gap: 0.75rem;
		flex: 1;
		min-height: 0;
	}
	.chart-card, .feed-card {
		background: #fff;
		border: 1px solid rgba(0,0,0,0.08);
		border-radius: 8px;
		padding: 1rem;
		overflow: hidden;
	}
	.card-title {
		font-size: 0.6875rem;
		font-weight: 500;
		color: rgba(0,0,0,0.4);
		margin-bottom: 0.875rem;
	}
	.chart-bars {
		display: flex;
		align-items: flex-end;
		gap: 4px;
		height: 100px;
		padding-bottom: 2px;
	}
	.chart-bars--tall { height: 140px; }
	.bar {
		flex: 1;
		background: rgba(0,0,0,0.08);
		border-radius: 2px 2px 0 0;
		transition: background 0.15s;
	}
	.bar:hover { background: rgba(0,0,0,0.18); }
	.bar.hi { background: #000; }
	.analytics-chart-full { flex: 1; }

	/* Feed */
	.feed-items { display: flex; flex-direction: column; gap: 0.75rem; }
	.feed-item { display: flex; align-items: flex-start; gap: 0.625rem; }
	.feed-dot {
		width: 7px; height: 7px; border-radius: 50%;
		flex-shrink: 0; margin-top: 3px;
	}
	.feed-dot.green { background: #16a34a; }
	.feed-dot.blue  { background: #2563eb; }
	.feed-dot.amber { background: #d97706; }
	.feed-action { font-size: 0.6875rem; color: rgba(0,0,0,0.75); font-weight: 500; margin-bottom: 1px; }
	.feed-time   { font-size: 0.5625rem; color: rgba(0,0,0,0.3); }

	/* Agents table */
	.agents-table { display: flex; flex-direction: column; border: 1px solid rgba(0,0,0,0.08); border-radius: 8px; overflow: hidden; background: #fff; }
	.agents-header {
		display: grid; grid-template-columns: 2fr 1fr 1fr 1fr;
		padding: 0.5rem 1rem;
		background: #fafafa;
		border-bottom: 1px solid rgba(0,0,0,0.07);
		font-size: 0.5625rem; font-weight: 600; color: rgba(0,0,0,0.35);
		text-transform: uppercase; letter-spacing: 0.06em;
	}
	.agents-row {
		display: grid; grid-template-columns: 2fr 1fr 1fr 1fr;
		padding: 0.5625rem 1rem;
		border-bottom: 1px solid rgba(0,0,0,0.05);
		align-items: center;
		transition: background 0.1s;
		cursor: default;
	}
	.agents-row:last-child { border-bottom: none; }
	.agents-row:hover { background: #fafafa; }
	.agent-name { display: flex; align-items: center; gap: 0.5rem; font-size: 0.75rem; font-weight: 500; color: #000; }
	.status-dot { width: 6px; height: 6px; border-radius: 50%; flex-shrink: 0; }
	.status-dot.green  { background: #16a34a; }
	.status-dot.amber  { background: #d97706; }
	.status-dot.gray   { background: rgba(0,0,0,0.2); }
	.agent-status { font-size: 0.6875rem; font-weight: 500; }
	.agent-status.running { color: #16a34a; }
	.agent-status.idle    { color: #d97706; }
	.agent-status.paused  { color: rgba(0,0,0,0.35); }
	.agent-tasks { font-size: 0.6875rem; color: rgba(0,0,0,0.6); }
	.agent-time  { font-size: 0.6875rem; color: rgba(0,0,0,0.35); }

	/* Integrations grid */
	.integrations-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.75rem; }
	.integration-card {
		display: flex; align-items: center; gap: 0.75rem;
		padding: 0.875rem 1rem;
		border: 1px solid rgba(0,0,0,0.08);
		border-radius: 8px; background: #fff;
		transition: box-shadow 0.15s;
		cursor: default;
	}
	.integration-card:hover { box-shadow: 0 2px 8px rgba(0,0,0,0.06); }
	.integration-card.connected { border-color: rgba(0,0,0,0.1); }
	.int-icon { width: 36px; height: 36px; border-radius: 8px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
	.int-name { font-size: 0.8125rem; font-weight: 600; color: #000; margin-bottom: 2px; }
	.int-status { font-size: 0.625rem; color: rgba(0,0,0,0.35); font-weight: 500; }
	.connected-txt { color: #16a34a; }

	/* ─── Responsive ─────────────────────────────────────────── */
	@media (max-width: 900px) {
		.founders-layout { grid-template-columns: 1fr; gap: 2.5rem; }
		.work-grid { grid-template-columns: 1fr; }
	}
	@media (max-width: 640px) {
		.nav-links { display: none; }
		.phases { grid-template-columns: 1fr; }
		.phase-item { border-right: none; border-bottom: 1px solid var(--border); }
		.phase-item:last-child { border-bottom: none; }
		.footer-inner { flex-direction: column; align-items: flex-start; gap: 1rem; }
		.footer-copy { margin-left: 0; }
		.hero-actions { flex-direction: column; align-items: center; }
	}

	/* ─── Aurora Background ───────────────────────────────────── */
	.hero-aurora {
		position: absolute;
		top: 0;
		left: 50%;
		transform: translateX(-50%);
		width: min(var(--max-w), 100vw);
		height: 100%;
		overflow: hidden;
		z-index: 0;
	}

	.aurora-blob {
		position: absolute;
		border-radius: 50%;
		filter: blur(100px);
		animation: aurora-shift 15s ease-in-out infinite;
	}

	.aurora-blob-1 {
		width: 350px;
		height: 350px;
		background: #3b82f6;
