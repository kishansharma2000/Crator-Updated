---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Book a Demo | Crator Labs">

	<div class="page-rails" aria-hidden="true"></div>

	<Nav />

	<main class="blog-main">

		<header class="blog-header">
			<h1>Let's talk AI.</h1>
			<p class="blog-tagline">Schedule a call and we'll show you what's possible.</p>
		</header>

		<section class="cal-embed">
		<iframe src="https://cal.com/yajat-gulati/ai-services?embed=true&embedType=Inline&layout=month_view&theme=light" title="Book a call" style="width:100%;height:100%;min-height:700px;border:none;"></iframe>
	</section>

		<section class="demo-fallback">
			<p>Prefer to reach out directly?</p>
			<a href="mailto:hello@cratorlabs.ai">hello@cratorlabs.ai</a>
		</section>

	</main>

	<Footer />

</Layout>

<style>
	:root {
		--bg: #fff;
		--surface: #f7f7f7;
		--border: rgba(0,0,0,0.08);
		--border-mid: rgba(0,0,0,0.14);
		--text-1: #000;
		--text-2: rgba(0,0,0,0.5);
		--text-3: rgba(0,0,0,0.3);
		--accent: #2563eb;
		--max-w: 1120px;
	}

	.page-rails {
		position: fixed;
		top: 0; bottom: 0;
		left: 50%; transform: translateX(-50%);
		width: min(var(--max-w), 100vw);
		pointer-events: none;
		z-index: 40;
		border-left: 1px solid var(--border);
		border-right: 1px solid var(--border);
	}

	.blog-main {
		max-width: var(--max-w);
		margin: 0 auto;
		padding: 8rem 2rem 6rem;
	}

	.blog-header {
		padding-bottom: 4rem;
		border-bottom: 1px solid var(--border);
		margin-bottom: 4rem;
	}
	.blog-header h1 {
		font-size: clamp(2.5rem, 5.5vw, 4rem);
		font-weight: 300;
		letter-spacing: -0.035em;
		line-height: 1.08;
		color: var(--text-1);
		margin-bottom: 1.25rem;
	}
	.blog-tagline {
		font-size: 1.0625rem;
		color: var(--text-2);
		line-height: 1.65;
		max-width: 480px;
	}

	.cal-embed {
		background: #fff;
		border: 1px solid var(--border);
		border-radius: 8px;
		overflow: hidden;
		min-height: 700px;
		margin-bottom: 3rem;
	}
	.layout-label {
		background: #f7f7f7;
		padding: 0.75rem 1rem;
		font-size: 0.875rem;
		font-weight: 500;
		color: var(--text-2);
		border-bottom: 1px solid var(--border);
	}

	.demo-fallback {
		text-align: center;
		margin-top: 2rem;
		padding: 2rem;
		background: var(--surface);
		border-radius: 8px;
	}

	.demo-fallback p {
		font-size: 0.9375rem;
		color: var(--text-2);
		margin: 0 0 0.5rem;
	}

	.demo-fallback a {
		font-size: 1rem;
		color: var(--text-1);
		text-decoration: none;
		font-weight: 500;
	}

	.demo-fallback a:hover {
		text-decoration: underline;
	}

	@media (max-width: 600px) {
		.blog-header h1 { font-size: 2rem; }
	}
</style>