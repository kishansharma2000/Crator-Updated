---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
---

<Layout title="Book a Demo | Crator Labs">
  <div class="page-rails" aria-hidden="true"></div>
  <Nav />

  <main class="demo-page">
    <div class="demo-container">
      <div class="demo-header">
        <h1>Book a Demo</h1>
        <p>See how Crator can transform your business with AI solutions tailored to your needs.</p>
      </div>

      <div class="demo-content">
        <!-- Cal.com Embed Placeholder -->
        <div class="cal-embed" id="cal-embed">
          <div class="cal-placeholder">
            <div class="cal-icon">
              <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
                <line x1="16" y1="2" x2="16" y2="6"/>
                <line x1="8" y1="2" x2="8" y2="6"/>
                <line x1="3" y1="10" x2="21" y2="10"/>
              </svg>
            </div>
            <p>Loading calendar...</p>
          </div>
        </div>

        <div class="demo-info">
          <h2>What to expect</h2>
          <ul>
            <li>
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="20 6 9 17 4 12"/>
              </svg>
              <span>30-minute strategy call with our AI experts</span>
            </li>
            <li>
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="20 6 9 17 4 12"/>
              </svg>
              <span>Custom AI solution recommendations for your business</span>
            </li>
            <li>
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="20 6 9 17 4 12"/>
              </svg>
              <span>ROI projections and implementation timeline</span>
            </li>
            <li>
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="20 6 9 17 4 12"/>
              </svg>
              <span>Q&A with our technical team</span>
            </li>
          </ul>

          <div class="demo-contact">
            <p>Prefer to reach out directly?</p>
            <a href="mailto:hello@cratorlabs.ai">hello@cratorlabs.ai</a>
          </div>
        </div>
      </div>
    </div>
  </main>
</Layout>

<style>
  .demo-page {
    min-height: 100vh;
    padding: 8rem 2rem 4rem;
    background: #fafafa;
  }

  .demo-container {
    max-width: 1000px;
    margin: 0 auto;
  }

  .demo-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .demo-header h1 {
    font-size: 2.5rem;
    font-weight: 600;
    color: #000;
    margin-bottom: 0.75rem;
    letter-spacing: -0.02em;
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  }

  .demo-header p {
    font-size: 1.125rem;
    color: rgba(0,0,0,0.6);
    max-width: 500px;
    margin: 0 auto;
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  }

  .demo-content {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 2rem;
    align-items: start;
  }

  @media (max-width: 900px) {
    .demo-content {
      grid-template-columns: 1fr;
    }
  }

  .cal-embed {
    background: #fff;
    border-radius: 16px;
    min-height: 600px;
    box-shadow: 0 2px 16px rgba(0,0,0,0.06);
    overflow: hidden;
    border: 1px solid rgba(0,0,0,0.08);
  }

  .cal-placeholder {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 600px;
    color: rgba(0,0,0,0.4);
  }

  .cal-icon {
    margin-bottom: 1rem;
    opacity: 0.5;
  }

  .cal-placeholder p {
    font-size: 0.875rem;
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  }

  .demo-info {
    background: #fff;
    border-radius: 16px;
    padding: 1.5rem;
    box-shadow: 0 2px 16px rgba(0,0,0,0.06);
    border: 1px solid rgba(0,0,0,0.08);
  }

  .demo-info h2 {
    font-size: 1.125rem;
    font-weight: 600;
    color: #000;
    margin-bottom: 1.25rem;
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  }

  .demo-info ul {
    list-style: none;
    padding: 0;
    margin: 0 0 1.5rem;
  }

  .demo-info li {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 0.625rem 0;
    font-size: 0.9375rem;
    color: rgba(0,0,0,0.75);
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  }

  .demo-info li svg {
    color: #4A93D6;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .demo-contact {
    padding-top: 1.25rem;
    border-top: 1px solid rgba(0,0,0,0.08);
  }

  .demo-contact p {
    font-size: 0.875rem;
    color: rgba(0,0,0,0.5);
    margin-bottom: 0.5rem;
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  }

  .demo-contact a {
    font-size: 0.9375rem;
    color: #4A93D6;
    text-decoration: none;
    font-weight: 500;
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  }

  .demo-contact a:hover {
    text-decoration: underline;
  }
</style>