---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
---

<Layout title="Book a Demo | Crator Labs">
  <div class="page-rails" aria-hidden="true"></div>
  <Nav />

  <main class="demo-main">
    <header class="demo-header">
      <p class="eyebrow">Book a Demo</p>
      <h1>Let's talk AI.</h1>
      <p class="tagline">Schedule a call and we'll show you what's possible.</p>
    </header>

    <section class="demo-content">
      <div class="cal-embed" id="cal-embed">
        <div class="cal-placeholder">
          <div class="cal-icon">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
              <line x1="16" y1="2" x2="16" y2="6"/>
              <line x1="8" y1="2" x2="8" y2="6"/>
              <line x1="3" y1="10" x2="21" y2="10"/>
            </svg>
          </div>
          <p>Loading calendar...</p>
        </div>
      </div>
    </section>

    <div class="demo-fallback">
      <p>Prefer to reach out directly?</p>
      <a href="mailto:hello@cratorlabs.ai">hello@cratorlabs.ai</a>
    </div>
  </main>

  <footer class="footer">
    <div class="footer-inner">
      <div class="footer-logo">
        <svg width="18" height="18" viewBox="0 0 32 32" fill="none"><rect width="32" height="32" rx="6" fill="#000"/><path d="M9 9h14v2H11v10h2V11h2v10h2V11h2v10h2V9H9v12H7v2h16v-2H9V9z" fill="#fff"/></svg>
        <span>Crator</span>
      </div>
      <div class="footer-links">
        <a href="/#services">Services</a>
        <a href="/portfolio">Work</a>
        <a href="/blog">Blog</a>
        <a href="/book-a-demo">Contact</a>
      </div>
      <p class="footer-copy">&copy; 2026 Crator Labs. Applied AI Company, Singapore.</p>
    </div>
  </footer>
</Layout>

<style is:global>
  :root {
    --bg: #fff;
    --surface: #f7f7f7;
    --border: rgba(0,0,0,0.08);
  }
  html {
    background: var(--bg);
    color: #000;
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  }
  body {
    margin: 0;
    padding: 0;
  }
  a {
    color: inherit;
  }
  .page-rails {
    position: fixed;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 1px;
    height: 100vh;
    background: var(--border);
    z-index: -1;
  }
  .page-rails::before,
  .page-rails::after {
    content: '';
    position: absolute;
    top: 0;
    height: 100vh;
    width: 1px;
    background: var(--border);
  }
  .page-rails::before { left: -240px; }
  .page-rails::after { left: 240px; }

  .footer {
    background: #fff;
    border-top: 1px solid var(--border);
    padding: 2rem 0;
    margin-top: 4rem;
  }
  .footer-inner {
    max-width: 1072px;
    margin: 0 auto;
    padding: 0 2rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }
  .footer-logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 600;
    font-size: 0.9375rem;
  }
  .footer-links {
    display: flex;
    gap: 1.5rem;
  }
  .footer-links a {
    color: rgba(0,0,0,0.5);
    text-decoration: none;
    font-size: 0.875rem;
    transition: color 0.15s;
  }
  .footer-links a:hover {
    color: #000;
  }
  .footer-copy {
    color: rgba(0,0,0,0.4);
    font-size: 0.8125rem;
    margin: 0;
  }
</style>

<style>
  .demo-main {
    padding: 8rem 2rem 4rem;
    max-width: 900px;
    margin: 0 auto;
  }

  .demo-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .eyebrow {
    font-size: 0.8125rem;
    font-weight: 500;
    color: #4A93D6;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin: 0 0 1rem;
  }

  .demo-header h1 {
    font-size: 3rem;
    font-weight: 600;
    color: #000;
    margin: 0 0 0.75rem;
    letter-spacing: -0.03em;
    line-height: 1.1;
  }

  .tagline {
    font-size: 1.125rem;
    color: rgba(0,0,0,0.6);
    margin: 0;
  }

  .demo-content {
    background: #fff;
    border-radius: 16px;
    min-height: 600px;
    box-shadow: 0 2px 16px rgba(0,0,0,0.06);
    overflow: hidden;
    border: 1px solid rgba(0,0,0,0.08);
  }

  .cal-placeholder {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 600px;
    color: rgba(0,0,0,0.4);
  }

  .cal-icon {
    margin-bottom: 1rem;
    opacity: 0.5;
  }

  .cal-placeholder p {
    font-size: 0.875rem;
  }

  .demo-fallback {
    text-align: center;
    margin-top: 2rem;
    padding: 1.5rem;
    background: #f7f7f7;
    border-radius: 12px;
  }

  .demo-fallback p {
    font-size: 0.875rem;
    color: rgba(0,0,0,0.5);
    margin: 0 0 0.5rem;
  }

  .demo-fallback a {
    font-size: 1rem;
    color: #4A93D6;
    text-decoration: none;
    font-weight: 500;
  }

  .demo-fallback a:hover {
    text-decoration: underline;
  }

  @media (max-width: 640px) {
    .demo-main {
      padding: 7rem 1.5rem 3rem;
    }
    .demo-header h1 {
      font-size: 2.25rem;
    }
  }
</style>