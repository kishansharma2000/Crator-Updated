---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
---

<Layout title="Work | Crator Labs" description="Case studies and products shipped by Crator Labs.">

	<div class="page-rails" aria-hidden="true"></div>
	<Nav active="work" />

	<main class="portfolio-main">
		<header class="portfolio-header">
			<p class="eyebrow">Our Work</p>
			<h1>Real systems.<br>Real results.</h1>
			<p class="tagline">Case studies, products, and experiments built for real businesses.</p>
		</header>

		<section class="case-studies">
			<p class="section-label">Client Work</p>
			<div class="cases-grid">
				<a href="/portfolio/flow-coffee-sales-agent" class="case-card">
					<div class="case-thumb"><img src="/images/sales-agent.webp" alt="Sales Agent" loading="lazy" /></div>
					<div class="case-body">
						<div class="case-meta">
							<span class="post-tag">AI Agent</span>
							<span class="post-date">Live</span>
						</div>
						<h3>Sales Agent</h3>
						<p>AI-powered sales pipeline management, lead tracking, and location prospecting — all accessible via Telegram.</p>
					</div>
					<div class="case-footer">
						<span class="case-client">Flow Coffee</span>
						<span class="case-arrow">→</span>
					</div>
				</a>
				<a href="/portfolio/flow-coffee-operations-agent" class="case-card">
					<div class="case-thumb"><img src="/images/operations-agent.webp" alt="Operations Agent" loading="lazy" /></div>
					<div class="case-body">
						<div class="case-meta">
							<span class="post-tag">AI Agent</span>
							<span class="post-date">Live</span>
						</div>
						<h3>Operations Agent</h3>
						<p>Operational intelligence across all machines — scheduled reports, anomaly detection, and ingredient forecasting.</p>
					</div>
					<div class="case-footer">
						<span class="case-client">Flow Coffee</span>
						<span class="case-arrow">→</span>
					</div>
				</a>
				<a href="/portfolio/flow-coffee-support-agent" class="case-card">
					<div class="case-thumb"><img src="/images/support-agent.webp" alt="Support Agent" loading="lazy" /></div>
					<div class="case-body">
						<div class="case-meta">
							<span class="post-tag">AI Agent</span>
							<span class="post-date">Live</span>
						</div>
						<h3>Support Agent</h3>
						<p>Automated customer support via WhatsApp — incident classification, logging, and redemption code dispatch.</p>
					</div>
					<div class="case-footer">
						<span class="case-client">Flow Coffee</span>
						<span class="case-arrow">→</span>
					</div>
				</a>
				<a href="/portfolio/flow-coffee-web-app" class="case-card">
					<div class="case-thumb"><img src="/images/ai-native-erp.webp" alt="AI-Native ERP" loading="lazy" /></div>
					<div class="case-body">
						<div class="case-meta">
							<span class="post-tag">Software</span>
							<span class="post-date">Live</span>
						</div>
						<h3>AI-Native ERP</h3>
						<p>Full-stack operations dashboard consolidating machine data, sales analytics, and CRM — replacing Google Sheets.</p>
					</div>
					<div class="case-footer">
						<span class="case-client">Flow Coffee</span>
						<span class="case-arrow">→</span>
					</div>
				</a>
				<a href="/portfolio/hoursense-legal-billing" class="case-card">
					<div class="case-thumb"><img src="/images/hour-sense.webp" alt="HourSense" loading="lazy" /></div>
					<div class="case-body">
						<div class="case-meta">
							<span class="post-tag">AI SaaS</span>
							<span class="post-date">Live</span>
						</div>
						<h3>HourSense — Legal Billing AI</h3>
						<p>AI-powered time tracking that automates billing for lawyers. Validated via a POC with one of India's largest law firms.</p>
					</div>
					<div class="case-footer">
						<span class="case-client">Top-5 Indian Law Firm</span>
						<span class="case-arrow">→</span>
					</div>
				</a>
				<a href="/portfolio/garment-supply-chain-erp" class="case-card">
					<div class="case-thumb"></div>
					<div class="case-body">
						<div class="case-meta">
							<span class="post-tag">Software</span>
							<span class="post-date">Live</span>
						</div>
						<h3>Garment Supply Chain ERP</h3>
						<p>Centralised supply chain and inventory management across 6 independent manufacturing units.</p>
					</div>
					<div class="case-footer">
						<span class="case-client">LM Trading</span>
						<span class="case-arrow">→</span>
					</div>
				</a>
			</div>
		</section>

		<section class="products">
			<p class="section-label">Products</p>
			<div class="cases-grid">
				<a href="/portfolio/askwaai" class="case-card">
					<div class="case-thumb"></div>
					<div class="case-body">
						<div class="case-meta">
							<span class="post-tag">AI SaaS</span>
							<span class="post-date">Live</span>
						</div>
						<h3>AskWaai — Writing Feedback AI</h3>
						<p>AI writing feedback platform for NTU's mandatory CC0001 course. Deployed to thousands of students.</p>
					</div>
					<div class="case-footer">
						<span class="case-client">NTU Singapore</span>
						<span class="case-arrow">→</span>
					</div>
				</a>
				<a href="/portfolio/yar-ai-pendant" class="case-card">
					<div class="case-thumb"></div>
					<div class="case-body">
						<div class="case-meta">
							<span class="post-tag">Hardware</span>
							<span class="post-date">Award</span>
						</div>
						<h3>yaR AI Pendant</h3>
						<p>Wearable AI device for visually impaired individuals. James Dyson Award finalist.</p>
					</div>
					<div class="case-footer">
						<span class="case-client">SAVH · James Dyson Award</span>
						<span class="case-arrow">→</span>
					</div>
				</a>
			</div>
		</section>
	</main>

	<footer class="portfolio-footer">
		<div class="footer-inner">
			<a href="/" class="footer-logo">
				<img src="https://www.cratorlabs.ai/_next/image?url=%2Ffull-logo.png&w=256&q=75" alt="Crator" height="22" />
			</a>
			<div class="footer-policies">
				<a href="/privacy">Privacy</a>
				<span class="footer-sep">·</span>
				<a href="/terms-of-service">Terms</a>
				<span class="footer-sep">·</span>
				<a href="https://trust.cratorlabs.ai" target="_blank" rel="noopener">Security</a>
			</div>
			<p class="footer-copy">&copy; 2026 Crator Labs. Applied AI Company, Singapore.</p>
		</div>
	</footer>

</Layout>

<style>
	:root {
		--bg: #fff;
		--surface: #f7f7f7;
		--border: rgba(0,0,0,0.08);
		--border-mid: rgba(0,0,0,0.14);
		--text-1: #000;
		--text-2: rgba(0,0,0,0.5);
		--text-3: rgba(0,0,0,0.3);
		--max-w: 1120px;
	}

	/* ─── Rails ─────────────────────────────────────────────── */
	.page-rails {
		position: fixed;
		top: 0; bottom: 0;
		left: 50%; transform: translateX(-50%);
		width: min(var(--max-w), 100vw);
		pointer-events: none; z-index: 40;
		border-left: 1px solid var(--border);
		border-right: 1px solid var(--border);
	}

	/* ─── Main ───────────────────────────────────────────────── */
	.portfolio-main {
		max-width: var(--max-w);
		margin: 0 auto;
		padding: 8rem 2rem 6rem;
	}

	/* ─── Header ─────────────────────────────────────────────── */
	.portfolio-header {
		padding-bottom: 4rem;
		border-bottom: 1px solid var(--border);
		margin-bottom: 4rem;
	}
	.eyebrow {
		font-size: 0.6875rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: var(--text-3);
		margin-bottom: 1rem;
	}
	.portfolio-header h1 {
		font-size: clamp(2.5rem, 5.5vw, 4rem);
		font-weight: 300;
		letter-spacing: -0.035em;
		line-height: 1.08;
		color: var(--text-1);
		margin-bottom: 1rem;
	}
	.tagline {
		font-size: 1.0625rem;
		color: var(--text-2);
		line-height: 1.65;
		max-width: 440px;
	}

	/* ─── Section label ──────────────────────────────────────── */
	.section-label {
		font-size: 0.625rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: var(--text-3);
		margin-bottom: 1.25rem;
	}
	.case-studies { margin-bottom: 4rem; }
	.products { margin-bottom: 4rem; }

	/* ─── Tags & meta ────────────────────────────────────────── */
	.post-tag {
		font-size: 0.5625rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.07em;
		color: var(--text-3);
		background: rgba(0,0,0,0.04);
		border: 1px solid var(--border);
		padding: 0.1875rem 0.5rem;
		border-radius: 3px;
	}
	.post-date {
		font-size: 0.6875rem;
		color: var(--text-3);
		font-weight: 500;
	}

/* ─── Grid ───────────────────────────────────────────────── */
	.cases-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1.25rem;
	}
	@media (max-width: 900px) {
		.cases-grid { grid-template-columns: repeat(2, 1fr); }
	}
	@media (max-width: 600px) {
		.cases-grid { grid-template-columns: 1fr; }
	}

/* ─── Card ───────────────────────────────────────────────── */
	.case-card {
		background: #fff;
		border: 1px solid var(--border);
		border-radius: 8px;
		overflow: hidden;
		text-decoration: none;
		color: inherit;
		display: flex;
		flex-direction: column;
		position: relative;
		transition: background 0.15s;
	}
	.case-card:hover { background: #fafafa; }
	.case-card:hover .case-arrow { opacity: 1; transform: translateX(0); }

	.case-thumb {
		width: 100%;
		aspect-ratio: 16/9;
		overflow: hidden;
		background: #f5f5f5;
	}
	.case-thumb img {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}
	.case-body {
		padding: 1.5rem 1.5rem 0.75rem;
		flex: 1;
		display: flex;
		flex-direction: column;
		gap: 0.625rem;
	}
	.case-meta {
		display: flex;
		align-items: center;
		gap: 0.5rem;
	}
	.case-card h3 {
		font-size: 1rem;
		font-weight: 400;
		color: var(--text-1);
		letter-spacing: -0.015em;
		line-height: 1.35;
	}
	.case-card p {
		font-size: 0.8125rem;
		color: var(--text-2);
		line-height: 1.65;
		flex: 1;
	}
	.case-footer {
		padding: 0.75rem 1.5rem 1.25rem;
		display: flex;
		align-items: center;
		justify-content: space-between;
	}
	.case-client {
		font-size: 0.625rem;
		font-weight: 600;
		color: var(--text-3);
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}
	.case-arrow {
		font-size: 1rem;
		color: var(--text-1);
		opacity: 0;
		transform: translateX(-6px);
		transition: opacity 0.2s, transform 0.2s;
	}

	/* ─── Footer ─────────────────────────────────────────────── */
	.portfolio-footer {
		border-top: 1px solid var(--border);
		padding: 2rem 2rem;
	}
	.footer-inner {
		max-width: var(--max-w);
		margin: 0 auto;
		display: flex;
		align-items: center;
		justify-content: space-between;
		flex-wrap: wrap;
		gap: 1.5rem;
	}
	.footer-logo {
		display: flex; align-items: center;
	}
	.footer-logo img { height: 22px; width: auto; }
	.footer-policies { display: flex; align-items: center; gap: 0.5rem; }
	.footer-policies a {
		font-size: 0.8125rem; color: var(--text-2);
		text-decoration: none; transition: color 0.15s;
	}
	.footer-policies a:hover { color: var(--text-1); }
	.footer-sep { color: var(--text-3); font-size: 0.75rem; }
	.footer-copy { font-size: 0.75rem; color: var(--text-3); }

	/* ─── Responsive ─────────────────────────────────────────── */
	@media (max-width: 900px) {
		.cases-grid { grid-template-columns: repeat(2, 1fr); }
	}
	@media (max-width: 600px) {
		.cases-grid { grid-template-columns: 1fr; }
		.portfolio-header h1 { font-size: 2rem; }
		.footer-inner { flex-direction: column; align-items: flex-start; gap: 1rem; }
		.footer-copy { margin-left: 0; }
	}
</style>
