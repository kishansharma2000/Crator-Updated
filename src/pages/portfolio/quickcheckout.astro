---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import CaseStudyCTA from '../../components/CaseStudyCTA.astro';
---

<Layout title="QuickCheckout | Crator">

	<div class="page-rails" aria-hidden="true"></div>

	<Nav active="work" />

	<section class="case-hero">
		<div class="back-link">
			<a href="/portfolio">← Back to portfolio</a>
		</div>
		<div class="case-meta">
			<span class="case-tag">Product</span>
			<span class="case-status prototype">prototype</span>
		</div>
		<h1>QuickCheckout</h1>
		<p class="case-sub">Mobile-first grocery checkout — skip the cashier queue. Equity-free grant from NTU Innovator's Track.</p>

		<div class="case-client">
			<span>NTU Garage</span>
		</div>
	</section>

	<section class="case-content">
		<div class="case-section">
			<h2>Background</h2>
			<p>QuickCheckout was incubated at NTU Garage and received an equity-free grant from NTU's Innovator's Track. It targets grocery retailers looking to reduce checkout friction and improve throughput during peak hours.</p>
		</div>

		<div class="case-section">
			<h2>The Problem</h2>
			<p>Grocery shoppers waste time in cashier queues, especially during peak hours. Retailers lose throughput and customer satisfaction to slow checkout processes — a problem that compounds at scale with no elegant software solution.</p>
		</div>

		<div class="case-section">
			<h2>What We Built</h2>
			<p>We built a mobile-first checkout app that lets shoppers scan items and pay directly from their phone, skipping the cashier queue entirely. Designed for in-store grocery retail with a lightweight, fast UX.</p>
		</div>

		<div class="case-section">
			<h2>Features</h2>
			<ul>
				<li>Scan and pay from your phone — no cashier needed</li>
				<li>Mobile-first design optimised for in-store grocery shopping</li>
				<li>Fast item lookup and real-time cart management</li>
				<li>Equity-free grant from NTU Innovator's Track</li>
				<li>Incubated at NTU Garage startup programme</li>
			</ul>
		</div>

		<div class="case-section">
			<h2>Tech Stack</h2>
			<div class="tech-tags">
				<span>React Native</span>
				<span>Mobile</span>
				<span>Retail</span>
				<span>NTU Garage</span>
			</div>
		</div>
	</section>

	<CaseStudyCTA />

	<Footer />

</Layout>

<style is:global>
	:root {
		--bg: #fff;
		--surface: #f7f7f7;
		--border: rgba(0,0,0,0.08);
		--border-mid: rgba(0,0,0,0.14);
		--text-1: #000;
		--text-2: rgba(0,0,0,0.5);
		--text-3: rgba(0,0,0,0.3);
		--max-w: 1120px;
	}
	html {
		background: var(--bg);
		color: var(--text-1);
		font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
	}
	body { margin: 0; padding: 0; }
	a { color: inherit; text-decoration: none; }
	.page-rails {
		position: fixed;
		top: 0; bottom: 0;
		left: 50%; transform: translateX(-50%);
		width: min(var(--max-w), 100vw);
		pointer-events: none;
		z-index: 40;
		border-left: 1px solid var(--border);
		border-right: 1px solid var(--border);
	}

	.case-hero {
		max-width: var(--max-w);
		margin: 0 auto;
		padding: 8rem 2rem 4rem;
	}
	.back-link {
		margin-bottom: 2rem;
	}
	.back-link a {
		font-size: 0.875rem;
		color: var(--text-2);
		transition: color 0.15s;
	}
	.back-link a:hover { color: var(--text-1); }
	.case-meta {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		margin-bottom: 1rem;
	}
	.case-tag {
		font-size: 0.6875rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--text-3);
		background: var(--surface);
		padding: 0.25rem 0.625rem;
		border-radius: 4px;
	}
	.case-status {
		font-size: 0.6875rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.04em;
		color: #16a34a;
	}
	.case-status.prototype {
		color: #d97706;
	}
	.case-hero h1 {
		font-size: clamp(2rem, 4vw, 3rem);
		font-weight: 400;
		letter-spacing: -0.03em;
		line-height: 1.15;
		margin: 0 0 1rem;
	}
	.case-sub {
		font-size: 1.125rem;
		color: var(--text-2);
		line-height: 1.6;
		max-width: 600px;
		margin-bottom: 2rem;
	}
	.case-client {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		margin-bottom: 1rem;
	}
	.case-client span {
		font-size: 0.9375rem;
		font-weight: 500;
	}

	.case-content {
		max-width: var(--max-w);
		margin: 0 auto;
		padding: 0 2rem 6rem;
	}
	.case-section {
		margin-bottom: 3rem;
	}
	.case-section h2 {
		font-size: 1.25rem;
		font-weight: 600;
		margin-bottom: 1rem;
	}
	.case-section p {
		font-size: 1rem;
		color: var(--text-2);
		line-height: 1.7;
		max-width: 720px;
	}
	.case-section ul {
		list-style: none;
		padding: 0;
		margin: 0;
	}
	.case-section li {
		font-size: 0.9375rem;
		color: var(--text-2);
		padding: 0.5rem 0;
		padding-left: 1.5rem;
		position: relative;
	}
	.case-section li::before {
		content: '';
		position: absolute;
		left: 0;
		top: 0.95rem;
		width: 6px;
		height: 6px;
		background: var(--text-3);
		border-radius: 50%;
	}
	.tech-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
	}
	.tech-tags span {
		font-size: 0.75rem;
		font-weight: 500;
		color: var(--text-2);
		background: var(--surface);
		padding: 0.375rem 0.75rem;
		border-radius: 4px;
		border: 1px solid var(--border);
	}

	@media (max-width: 640px) {
		.case-hero { padding: 7rem 1.5rem 3rem; }
		.case-content { padding: 0 1.5rem 4rem; }
		.case-hero h1 { font-size: 1.75rem; }
	}
</style>
