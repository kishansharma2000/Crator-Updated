				</a>
			</div>
		</div>
	</section>

	<Footer />
</Layout>

<style>
	:root {
		--bg: #fff;
		--surface: #f7f7f7;
		--border: rgba(0,0,0,0.08);
		--border-mid: rgba(0,0,0,0.14);
		--text-1: #000;
		--text-2: rgba(0,0,0,0.5);
		--text-3: rgba(0,0,0,0.3);
		--max-w: 1120px;
	}

	.page-rails {
		position: fixed;
		top: 0;
		bottom: 0;
		left: 50%;
		transform: translateX(-50%);
		width: min(var(--max-w), 100vw);
		pointer-events: none;
		z-index: 40;
		border-left: 1px solid var(--border);
		border-right: 1px solid var(--border);
	}

	.typo-hero {
		padding: 8rem 2rem 4rem;
		text-align: center;
	}

	.typo-title {
		font-family: 'Inter', sans-serif;
		font-size: clamp(2rem, 5vw, 3.5rem);
		font-weight: 600;
		line-height: 1.1;
		letter-spacing: -0.03em;
		color: var(--text-1);
		margin-bottom: 1rem;
	}

	.typo-sub {
		font-size: 1.125rem;
		color: var(--text-2);
		line-height: 1.65;
		max-width: 560px;
		margin: 0 auto;
	}

	.section-inner {
		max-width: var(--max-w);
		margin: 0 auto;
		padding: 4rem 2rem;
	}

	.section-tag {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		font-size: 0.6875rem;
		font-weight: 600;
		color: var(--text-3);
		letter-spacing: 0.08em;
		text-transform: uppercase;
		margin-bottom: 1rem;
	}

	.section-header {
		margin-bottom: 3rem;
	}

	.section-heading {
		font-size: clamp(1.75rem, 4vw, 2.5rem);
		font-weight: 300;
		line-height: 1.1;
		letter-spacing: -0.03em;
		color: var(--text-1);
		margin-bottom: 1rem;
	}

	.section-sub {
		font-size: 1rem;
		color: var(--text-2);
		line-height: 1.7;
		max-width: 520px;
	}

	.font-variant {
		background: var(--bg);
	}

	.font-variant--alt {
		background: var(--surface);
	}

	/* Section Font Classes */
	#inter .section-heading,
	#inter .section-sub,
	#inter .cs-card h3,
	#inter .cs-card p,
	#inter .cs-card .cs-tag,
	#inter .cs-card .cs-foot {
		font-family: 'Inter', sans-serif !important;
	}

	#funnel-sans .section-heading,
	#funnel-sans .section-sub,
	#funnel-sans .cs-card h3,
	#funnel-sans .cs-card p,
	#funnel-sans .cs-card .cs-tag,
	#funnel-sans .cs-card .cs-foot {
		font-family: 'Funnel Sans', sans-serif !important;
	}

	#funnel-display .section-heading,
	#funnel-display .section-sub,
	#funnel-display .cs-card h3,
	#funnel-display .cs-card p,
	#funnel-display .cs-card .cs-tag,
	#funnel-display .cs-card .cs-foot {
		font-family: 'Funnel Display', sans-serif !important;
	}

	#geist .section-heading,
	#geist .section-sub,
	#geist .cs-card h3,
	#geist .cs-card p,
	#geist .cs-card .cs-tag,
	#geist .cs-card .cs-foot {
		font-family: 'Geist', sans-serif !important;
	}

	/* Case Study Card Styles */
	.cs-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1.25rem;
	}

	.cs-card {
		background: #fff;
		border: 1px solid var(--border);
		border-radius: 10px;
		overflow: hidden;
		text-decoration: none;
		color: inherit;
		display: flex;
		flex-direction: column;
		transition: background 0.15s;
	}

	.cs-card:hover { background: #fafafa; }
	.cs-card:hover .cs-arrow { opacity: 1; transform: translateX(0); }

	.cs-thumb {
		width: 100%;
		aspect-ratio: 16/9;
		overflow: hidden;
		background: #f5f5f5;
	}

	.cs-thumb img {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.cs-body {
		padding: 1.25rem 1.25rem 0.5rem;
		flex: 1;
		display: flex;
		flex-direction: column;
		gap: 0.375rem;
	}

	.cs-tag {
		font-size: 0.625rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		color: var(--text-3);
	}

	.cs-card h3 {
		font-size: 1rem;
		font-weight: 500;
		color: var(--text-1);
		letter-spacing: -0.01em;
	}

	.cs-card p {
		font-size: 0.8125rem;
		color: var(--text-2);
		line-height: 1.6;
		flex: 1;
	}

	.cs-foot {
		padding: 0.625rem 1.25rem 1rem;
		display: flex;
		align-items: center;
		justify-content: space-between;
		font-size: 0.625rem;
		font-weight: 600;
		color: var(--text-3);
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}

	.cs-arrow {
		font-size: 1rem;
		color: var(--text-1);
		opacity: 0;
		transform: translateX(-6px);
		transition: opacity 0.2s, transform 0.2s;
	}

	@media (max-width: 900px) {
		.cs-grid { grid-template-columns: repeat(2, 1fr); }
	}

	@media (max-width: 640px) {
		.cs-grid { grid-template-columns: 1fr; }
	}
</style>