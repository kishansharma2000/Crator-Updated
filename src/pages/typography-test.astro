---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Typography Test | Crator AI" useGeist={false}>
	<div class="page-rails" aria-hidden="true"></div>
	<Nav active="typography-test" />

	<section class="typo-hero">
		<div class="section-inner">
			<p class="section-tag">Typography Test</p>
			<h1 class="typo-title">Testing Font Families</h1>
			<p class="typo-sub">Comparing Inter, Funnel Sans, Funnel Display, and Geist to find the best fit for our brand.</p>
		</div>
	</section>

	<!-- INTER -->
	<section class="font-variant" id="inter">
		<div class="section-inner">
			<div class="section-header">
				<p class="section-tag">Font Family 01</p>
				<h2 class="section-heading font-inter">Inter</h2>
				<p class="section-sub font-inter">The classic. Clean, neutral, and highly legible at all sizes. Great for UI and body text.</p>
			</div>
			<div class="cs-grid">
				<a href="/portfolio/flow-coffee-sales-agent" class="cs-card">
					<div class="cs-thumb"><img src="/images/flow_sales_bot_1x.webp" alt="Sales Agent" loading="lazy" /></div>
					<div class="cs-body">
						<span class="cs-tag">AI Agent</span>
						<h3>Sales Agent</h3>
						<p>AI-powered sales pipeline management via Telegram.</p>
					</div>
					<div class="cs-foot"><span>Flow Coffee</span><span class="cs-arrow">→</span></div>
				</a>
				<a href="/portfolio/flow-coffee-operations-agent" class="cs-card">
					<div class="cs-thumb"><img src="/images/flow_ops_bot_1x.webp" alt="Operations Agent" loading="lazy" /></div>
					<div class="cs-body">
						<span class="cs-tag">AI Agent</span>
						<h3>Operations Agent</h3>
						<p>Anomaly detection, forecasting, and KPI tracking across all machines.</p>
					</div>
					<div class="cs-foot"><span>Flow Coffee</span><span class="cs-arrow">→</span></div>
				</a>
				<a href="/portfolio/flow-coffee-support-agent" class="cs-card">
					<div class="cs-thumb"><img src="/images/whatsapp_support_bot_flow_1x.webp" alt="Support Agent" loading="lazy" /></div>
					<div class="cs-body">
						<span class="cs-tag">AI Agent</span>
						<h3>Support Agent</h3>
						<p>Automated customer support via WhatsApp with incident logging.</p>
					</div>
					<div class="cs-foot"><span>Flow Coffee</span><span class="cs-arrow">→</span></div>
				</a>
			</div>
		</div>
	</section>

	<!-- FUNNEL SANS -->
	<section class="font-variant font-variant--alt" id="funnel-sans">
		<div class="section-inner">
			<div class="section-header">
				<p class="section-tag">Font Family 02</p>
				<h2 class="section-heading font-funnel-sans">Funnel Sans</h2>
				<p class="section-sub font-funnel-sans">Modern geometric sans-serif with a friendly, approachable feel. Perfect for startups.</p>
			</div>
			<div class="cs-grid">
				<a href="/portfolio/flow-coffee-sales-agent" class="cs-card">
					<div class="cs-thumb"><img src="/images/flow_sales_bot_1x.webp" alt="Sales Agent" loading="lazy" /></div>
					<div class="cs-body">
						<span class="cs-tag">AI Agent</span>
						<h3>Sales Agent</h3>
						<p>AI-powered sales pipeline management via Telegram.</p>
					</div>
					<div class="cs-foot"><span>Flow Coffee</span><span class="cs-arrow">→</span></div>
				</a>
				<a href="/portfolio/flow-coffee-operations-agent" class="cs-card">
					<div class="cs-thumb"><img src="/images/flow_ops_bot_1x.webp" alt="Operations Agent" loading="lazy" /></div>
					<div class="cs-body">
						<span class="cs-tag">AI Agent</span>
