					<div class="cs-thumb"><img src="/images/whatsapp_support_bot_flow_1x.webp" alt="Support Agent" loading="lazy" /></div>
					<div class="cs-body">
						<span class="cs-tag">AI Agent</span>
						<h3>Support Agent</h3>
						<p>Automated customer support via WhatsApp with incident logging.</p>
					</div>
					<div class="cs-foot"><span>Flow Coffee</span><span class="cs-arrow">→</span></div>
				</a>
			</div>
		</div>
	</section>

	<!-- FUNNEL DISPLAY -->
	<section class="font-variant" id="funnel-display">
		<div class="section-inner">
			<div class="section-header">
				<p class="section-tag">Font Family 03</p>
				<h2 class="section-heading font-funnel-display">Funnel Display</h2>
				<p class="section-sub font-funnel-display">Bold and expressive display font. Best for headlines and large-scale typography.</p>
			</div>
			<div class="cs-grid">
